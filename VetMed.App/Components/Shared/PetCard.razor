@using VetMed.Shared.DTOs
@using VetMed.Shared.Enums

<div class="pet-card" @onclick="() => OnClick.InvokeAsync()">
    <div class="pet-card-top">
        <div class="pet-emoji-wrap">@SpeciesEmoji(Pet.Species)</div>
        <div class="pet-age-badge">@PetAge(Pet.Born)</div>
    </div>
    <div class="pet-card-info">
        <div class="pet-name">@Pet.Name</div>
        @if (!string.IsNullOrEmpty(Pet.Breed))
        {
            <div class="pet-breed">@Pet.Breed</div>
        }
        @if (Pet.WeightKg.HasValue)
        {
            <div class="pet-weight">@Pet.WeightKg kg</div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PetDto Pet { get; set; } = default!;
    [Parameter] public EventCallback OnClick { get; set; }

    private static string SpeciesEmoji(Species s) => s switch
    {
        Species.Kot    => "🐱",
        Species.Pies   => "🐶",
        Species.Krolik => "🐰",
        Species.Ptak   => "🐦",
        _              => "🐾"
    };

    private static string PetAge(DateOnly born)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - born.Year) * 12 + today.Month - born.Month;
        if (today.Day < born.Day) months--;
        if (months < 12) return $"{months} mies.";
        var years = months / 12;
        return years == 1 ? "1 rok" : $"{years} lat";
    }
}

<style>
    .pet-card {
        background: #352010;
        border: 1px solid rgba(232,144,106,0.2);
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.15s;
        min-width: 130px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
    }

    .pet-card:active { transform: scale(0.96); }
    .pet-card:hover { border-color: rgba(232,144,106,0.45); }

    .pet-card-top {
        position: relative;
        background: rgba(232,144,106,0.08);
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pet-emoji-wrap {
        font-size: 44px;
        line-height: 1;
    }

    .pet-age-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px);
        border-radius: 8px;
        padding: 3px 7px;
        border: 1px solid rgba(255,255,255,0.15);
        font-size: 10px;
        font-weight: 600;
        color: rgba(245,237,229,0.85);
    }

    .pet-card-info {
        padding: 10px 12px 12px;
    }

    .pet-name {
        font-size: 14px;
        font-weight: 700;
        color: #F5EDE5;
    }

    .pet-breed {
        font-size: 11px;
        color: rgba(245,237,229,0.5);
        margin-top: 2px;
    }

    .pet-weight {
        font-size: 11px;
        color: rgba(245,237,229,0.45);
        margin-top: 2px;
    }
</style>
