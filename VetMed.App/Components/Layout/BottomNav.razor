@inject NavigationManager Nav
@inject AppState AppState
@inject NotificationService Notif
@implements IDisposable

<div class="nav-wrapper">
    <nav class="bottom-nav">
        <NavLink href="/" Match="NavLinkMatch.All" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/>
                    <polyline points="9 21 9 13 15 13 15 21"/>
                </svg>
            </span>
            <span class="nav-label">Dom</span>
        </NavLink>
        <NavLink href="/book-visit" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </span>
            <span class="nav-label">Umów</span>
        </NavLink>
        <NavLink href="/pets" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="4" r="2"/>
                    <circle cx="18" cy="8" r="2"/>
                    <circle cx="20" cy="16" r="2"/>
                    <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
                </svg>
            </span>
            <span class="nav-label">Zwierzaki</span>
        </NavLink>
        <NavLink href="/history" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </span>
            <span class="nav-label">Wizyty</span>
        </NavLink>
        <button class="nav-tab nav-more-btn @(moreOpen ? "nav-active" : "")" @onclick="ToggleMore">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/>
                </svg>
                @if (Notif.UnreadCount > 0)
                {
                    <span class="nav-badge">@(Notif.UnreadCount > 9 ? "9+" : Notif.UnreadCount.ToString())</span>
                }
            </span>
            <span class="nav-label">Więcej</span>
        </button>
    </nav>
</div>

@if (moreOpen)
{
    <div class="more-overlay" @onclick="CloseMore"></div>
    <div class="more-popup">
        <div class="more-handle"></div>
        <button class="more-item" @onclick='() => Go("/profile")'>
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
            </span>
            <span class="more-item-text">
                <span class="more-item-title">Profil</span>
                <span class="more-item-sub">Twoje konto i zwierzaki</span>
            </span>
            <span class="more-item-chev">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
        </button>
        <button class="more-item" @onclick="CloseMore">
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                    <line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
            </span>
            <span class="more-item-text">
                <span class="more-item-title">Płatności</span>
                <span class="more-item-sub">Historia i metody płatności</span>
            </span>
            <span class="more-item-chev">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
        </button>
        <button class="more-item" @onclick='() => Go("/notifications")'>
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                @if (Notif.UnreadCount > 0)
                {
                    <span class="item-badge">@(Notif.UnreadCount > 9 ? "9+" : Notif.UnreadCount.ToString())</span>
                }
            </span>
            <span class="more-item-text">
                <span class="more-item-title">Powiadomienia</span>
                <span class="more-item-sub">@(Notif.UnreadCount > 0 ? $"{Notif.UnreadCount} nieprzeczytane" : "Alerty i przypomnienia")</span>
            </span>
            <span class="more-item-chev">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
        </button>
        <button class="more-item" @onclick='() => Go("/settings")'>
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
            </span>
            <span class="more-item-text">
                <span class="more-item-title">Ustawienia</span>
                <span class="more-item-sub">Motyw, język, hasło</span>
            </span>
            <span class="more-item-chev">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
        </button>
        <button class="more-item more-item-danger" @onclick="Logout">
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </span>
            <span class="more-item-text">
                <span class="more-item-title">Wyloguj się</span>
                <span class="more-item-sub">Zakończ sesję</span>
            </span>
        </button>
    </div>
}

@code {
    private bool moreOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        Notif.OnChange += OnNotifChanged;
    }

    protected override async Task OnInitializedAsync() => await Notif.RefreshAsync();

    private void OnNotifChanged() => InvokeAsync(StateHasChanged);

    private void ToggleMore() => moreOpen = !moreOpen;
    private void CloseMore() => moreOpen = false;

    private void Go(string url)
    {
        moreOpen = false;
        Nav.NavigateTo(url);
    }

    private void Logout()
    {
        moreOpen = false;
        AppState.ClearAuth();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        moreOpen = false;
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            try
            {
                await Notif.RefreshAsync();
            }
            catch
            {
                // brak połączenia — ignorujemy odświeżenie licznika
            }
        });
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Notif.OnChange -= OnNotifChanged;
    }
}

<style>
    .nav-wrapper {
        width: 100%;
        background: linear-gradient(180deg, transparent 0%, var(--bg) 55%);
        padding: 24px 8px calc(14px + env(safe-area-inset-bottom));
        flex-shrink: 0;
        z-index: 200;
    }

    .bottom-nav {
        display: flex;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 8px 2px;
        box-shadow: var(--navShadow);
    }

    .nav-tab {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        text-decoration: none;
        color: var(--muted);
        flex: 1;
        background: transparent;
        border: none;
        cursor: pointer;
        border-radius: 12px;
        padding: 6px 2px;
        transition: color 0.2s, background 0.2s;
    }

    .nav-tab.nav-active {
        color: var(--mint);
        background: var(--mintGlow);
    }

    .nav-tab.nav-active .nav-label { font-weight: 700; color: var(--mint); }

    .nav-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
    }

    .nav-label {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.2px;
    }

    .nav-icon { position: relative; }

    .nav-badge {
        position: absolute;
        top: -5px;
        right: -7px;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        border-radius: 8px;
        background: var(--danger);
        color: #fff;
        font-size: 9px;
        font-weight: 800;
        line-height: 16px;
        text-align: center;
        border: 2px solid var(--surface);
        box-sizing: content-box;
    }

    .item-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        border-radius: 8px;
        background: var(--danger);
        color: #fff;
        font-size: 9px;
        font-weight: 800;
        line-height: 16px;
        text-align: center;
        border: 2px solid var(--surface);
    }

    .more-item-icon { position: relative; }

    .more-overlay {
        position: fixed;
        inset: 0;
        background: var(--overlay);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        z-index: 300;
    }

    .more-popup {
        position: fixed;
        bottom: 0;
        left: 8px;
        right: 8px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-bottom: none;
        border-radius: 20px 20px 0 0;
        padding: 10px 0 max(28px, env(safe-area-inset-bottom));
        z-index: 400;
        display: flex;
        flex-direction: column;
        box-shadow: var(--navShadow);
        animation: slideUp 0.22s cubic-bezier(0.22,1,0.36,1) both;
    }

    @@keyframes slideUp {
        from { transform: translateY(24px); opacity: 0; }
        to   { transform: translateY(0); opacity: 1; }
    }

    .more-handle {
        width: 36px;
        height: 4px;
        background: var(--faint);
        border-radius: 2px;
        margin: 0 auto 8px;
    }

    .more-item {
        display: flex;
        align-items: center;
        gap: 14px;
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--faint);
        padding: 13px 20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        width: 100%;
        text-align: left;
        transition: background 0.15s;
    }

    .more-item:last-child { border-bottom: none; }
    .more-item:active { background: var(--faint); }

    .more-item-icon {
        width: 38px;
        height: 38px;
        background: var(--mintGlow);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mint);
        flex-shrink: 0;
    }

    .more-item-text { display: flex; flex-direction: column; flex: 1; min-width: 0; }
    .more-item-title { font-size: 14px; font-weight: 700; color: var(--text); }
    .more-item-sub { font-size: 11px; color: var(--muted); margin-top: 1px; }
    .more-item-chev { color: var(--muted); display: flex; flex-shrink: 0; }

    .more-item-danger .more-item-icon { background: var(--dangerBg); color: var(--danger); }
    .more-item-danger .more-item-title { color: var(--danger); }
</style>
