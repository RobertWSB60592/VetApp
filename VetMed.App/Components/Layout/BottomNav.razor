@inject NavigationManager Nav
@implements IDisposable

<div class="nav-wrapper">
    <nav class="bottom-nav">
        <NavLink href="/" Match="NavLinkMatch.All" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
                    <polyline points="9 21 9 12 15 12 15 21"/>
                </svg>
            </span>
            <span class="nav-label">Dom</span>
        </NavLink>
        <NavLink href="/book-visit" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </span>
            <span class="nav-label">Umów</span>
        </NavLink>
        <NavLink href="/pets" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="4" r="2"/>
                    <circle cx="18" cy="8" r="2"/>
                    <circle cx="20" cy="16" r="2"/>
                    <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
                </svg>
            </span>
            <span class="nav-label">Zwierzaki</span>
        </NavLink>
        <NavLink href="/history" class="nav-tab" ActiveClass="nav-active">
            <span class="nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </span>
            <span class="nav-label">Wizyty</span>
        </NavLink>
        <button class="nav-tab nav-more-btn" @onclick="OpenMore">
            <span class="nav-icon nav-dots">
                <span></span><span></span><span></span>
            </span>
            <span class="nav-label">Więcej</span>
        </button>
    </nav>
</div>

@if (moreOpen)
{
    <div class="more-overlay" @onclick="CloseMore"></div>
    <div class="more-popup">
        <div class="more-handle"></div>
        <div class="more-title">Więcej opcji</div>
        <button class="more-item" @onclick="CloseMore">
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                    <line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
            </span>
            Płatności
        </button>
        <button class="more-item" @onclick="CloseMore">
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </span>
            Powiadomienia
        </button>
        <button class="more-item" @onclick="CloseMore">
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
            </span>
            Ustawienia
        </button>
        <button class="more-item more-item-danger" @onclick="CloseMore">
            <span class="more-item-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </span>
            Wyloguj się
        </button>
    </div>
}

@code {
    private bool moreOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OpenMore() => moreOpen = true;
    private void CloseMore() => moreOpen = false;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        moreOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}

<style>
    .nav-wrapper {
        width: 100%;
        background: var(--surface, #F8FCF9);
        border-top: 1px solid rgba(60,184,122,0.15);
        padding: 6px 0 max(16px, env(safe-area-inset-bottom));
        flex-shrink: 0;
        z-index: 200;
    }

    .bottom-nav {
        display: flex;
        justify-content: space-around;
        background: transparent;
        padding: 0 4px;
    }

    .nav-tab {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        text-decoration: none;
        color: rgba(26,44,34,0.45);
        flex: 1;
        background: transparent;
        border: none;
        cursor: pointer;
        border-radius: 14px;
        padding: 6px 4px;
        transition: color 0.2s, background 0.2s;
    }

    .nav-tab.nav-active {
        color: #3CB87A;
        background: rgba(60,184,122,0.15);
    }

    .nav-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
    }

    .nav-dots {
        flex-direction: row;
        gap: 3px;
    }

    .nav-dots span {
        display: block;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: currentColor;
    }

    .nav-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.2px;
    }

    .more-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.15);
        z-index: 300;
    }

    .more-popup {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: #EDF7F1;
        border: 1px solid rgba(60,184,122,0.2);
        border-bottom: none;
        border-radius: 24px 24px 0 0;
        padding: 12px 16px max(32px, env(safe-area-inset-bottom));
        z-index: 400;
        display: flex;
        flex-direction: column;
        gap: 4px;
        animation: slideUp 0.25s ease;
    }

    @@keyframes slideUp {
        from { transform: translateY(100%); }
        to   { transform: translateY(0); }
    }

    .more-handle {
        width: 40px;
        height: 4px;
        background: rgba(26,44,34,0.2);
        border-radius: 2px;
        margin: 0 auto 16px;
    }

    .more-title {
        font-size: 13px;
        font-weight: 700;
        color: rgba(26,44,34,0.45);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        padding: 0 4px;
        margin-bottom: 8px;
    }

    .more-item {
        display: flex;
        align-items: center;
        gap: 14px;
        background: transparent;
        border: none;
        border-radius: 14px;
        padding: 14px 12px;
        font-size: 15px;
        font-weight: 600;
        color: #1A2C22;
        cursor: pointer;
        width: 100%;
        text-align: left;
        transition: background 0.15s;
    }

    .more-item:hover, .more-item:active { background: rgba(60,184,122,0.1); }

    .more-item-icon {
        width: 36px;
        height: 36px;
        background: rgba(26,44,34,0.08);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3CB87A;
        flex-shrink: 0;
    }

    .more-item-danger { color: #FF7070; }
    .more-item-danger .more-item-icon { color: #FF7070; }
</style>
