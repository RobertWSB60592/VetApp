@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    @if (AppState.IsAuthenticated)
    {
        <main class="page-content">
            @Body
        </main>
        <BottomNav />
    }
</div>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !AppState.IsAuthenticated)
        {
            var restored = await AppState.TryRestoreAsync();
            if (!AppState.IsAuthenticated)
                Nav.NavigateTo("/login", replace: true);
            else if (restored)
                StateHasChanged();
        }
    }

    private void OnStateChanged()
    {
        InvokeAsync(() =>
        {
            if (!AppState.IsAuthenticated)
                Nav.NavigateTo("/login", replace: true);
            StateHasChanged();
        });
    }

    public void Dispose() => AppState.OnChange -= OnStateChanged;
}

<style>
    .app-shell {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        background: var(--bg);
    box-shadow: inset -1px 0 0 rgba(60,184,122,0.06);
        width: 100%;
        max-width: 430px;
        position: relative;
        overflow: hidden;
    }

    .page-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding-bottom: 90px;
        scrollbar-width: none;
    }

    .page-content::-webkit-scrollbar { display: none; }
</style>
