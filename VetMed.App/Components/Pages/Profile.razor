@page "/profile"
@inject AppState AppState
@inject IPetApiService PetApi
@inject NavigationManager Nav

<div class="profile-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div class="page-title">Profil</div>
    </div>

    <div class="user-card">
        <div class="user-avatar">@Initial</div>
        <div class="user-name">@FullName</div>
        @if (!string.IsNullOrWhiteSpace(Email))
        {
            <div class="user-email">@Email</div>
        }
        <div class="user-stats">
            <div class="stat">
                <span class="stat-num">@petCount</span>
                <span class="stat-label">@PetWord(petCount)</span>
            </div>
        </div>
    </div>

    <div class="section-label">Twoje zwierzaki</div>
    @if (loading)
    {
        <LoadingSpinner />
    }
    else if (pets.Count == 0)
    {
        <div class="empty-msg">Nie masz jeszcze zwierzaków.</div>
    }
    else
    {
        <div class="pet-list">
            @foreach (var p in pets)
            {
                var pid = p.Id;
                <button class="pet-row" @onclick='() => Nav.NavigateTo($"/pets/{pid}")' @key="p.Id">
                    <span class="pet-emoji">@PetVisuals.Emoji(p.Species)</span>
                    <span class="pet-body">
                        <span class="pet-name">@p.Name</span>
                        <span class="pet-sub">@p.Species@(string.IsNullOrEmpty(p.Breed) ? "" : " · " + p.Breed)</span>
                    </span>
                    <span class="pet-chev">›</span>
                </button>
            }
        </div>
    }

    <div class="section-label">Konto</div>
    <div class="links-card">
        <button class="link-row" @onclick='() => Nav.NavigateTo("/settings")'>
            <span class="link-text">Ustawienia aplikacji</span>
            <span class="chev">›</span>
        </button>
        <button class="link-row" @onclick='() => Nav.NavigateTo("/clinic")'>
            <span class="link-text">Informacje o przychodni</span>
            <span class="chev">›</span>
        </button>
        <button class="link-row" @onclick='() => Nav.NavigateTo("/notifications")'>
            <span class="link-text">Powiadomienia</span>
            <span class="chev">›</span>
        </button>
    </div>

    <button class="logout-btn" @onclick="Logout">Wyloguj się</button>
</div>

@code {
    private List<PetDto> pets = new();
    private bool loading = true;
    private int petCount;

    private string FullName => AppState.CurrentOwner?.FullName ?? "Użytkownik";
    private string? Email => AppState.CurrentOwner?.Email;
    private string Initial => string.IsNullOrWhiteSpace(FullName) ? "U" : FullName.Trim()[0].ToString().ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        petCount = AppState.CurrentOwner?.PetCount ?? 0;
        try
        {
            pets = await PetApi.GetPetsAsync();
            petCount = pets.Count;
        }
        catch { }
        finally { loading = false; }
    }

    private void Logout() => AppState.ClearAuth();

    private static string PetWord(int n) => n == 1 ? "zwierzak" : "zwierzaków";
}

<style>
    .profile-page { padding: 20px 16px 8px; display: flex; flex-direction: column; }

    .page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding-top: 8px;
        margin-bottom: 18px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
    }

    .page-title { font-size: 20px; font-weight: 800; color: var(--text); }

    .user-card {
        background: linear-gradient(135deg, var(--mintGlow), transparent);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: var(--cardShadow);
        padding: 24px 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 4px;
    }

    .user-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: var(--mint);
        color: var(--onMint);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .user-name { font-size: 19px; font-weight: 800; color: var(--text); }
    .user-email { font-size: 13px; color: var(--muted); }

    .user-stats { display: flex; gap: 18px; margin-top: 12px; }
    .stat { display: flex; flex-direction: column; align-items: center; }
    .stat-num { font-size: 20px; font-weight: 800; color: var(--mint); }
    .stat-label { font-size: 11px; color: var(--muted); }

    .section-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin: 18px 4px 10px;
    }

    .pet-list { display: flex; flex-direction: column; gap: 8px; }

    .pet-row {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        text-align: left;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 12px 14px;
        box-shadow: var(--cardShadow);
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: transform 0.12s, border-color 0.2s;
    }

    .pet-row:active { transform: scale(0.99); border-color: var(--mint); }

    .pet-emoji {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--mintGlow);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .pet-body { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .pet-name { font-size: 14px; font-weight: 700; color: var(--text); }
    .pet-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }
    .pet-chev { color: var(--muted); font-size: 20px; line-height: 1; flex-shrink: 0; }

    .empty-msg {
        font-size: 13px;
        color: var(--muted);
        text-align: center;
        padding: 20px 0;
    }

    .links-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--cardShadow);
        overflow: hidden;
    }

    .link-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--faint);
        padding: 15px 16px;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .link-row:last-child { border-bottom: none; }
    .link-row:active { background: var(--faint); }
    .link-text { font-size: 14px; font-weight: 600; color: var(--text); }
    .chev { color: var(--muted); font-size: 20px; line-height: 1; }

    .logout-btn {
        margin-top: 22px;
        background: var(--dangerBg);
        border: 1px solid var(--danger);
        color: var(--danger);
        border-radius: 14px;
        padding: 14px;
        font-size: 15px;
        font-weight: 700;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
    }
</style>
