@page "/pets/add"
@inject IPetApiService PetApi
@inject ApiClient Api
@inject NavigationManager Nav

<div class="add-pet-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/pets")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div>
            <div class="page-title">Dodaj zwierzaka</div>
            <div class="page-sub">Uzupełnij profil pupila</div>
        </div>
    </div>

    @if (success)
    {
        <div class="success-screen">
            <div class="success-rings">
                <div class="ring ring-1"></div>
                <div class="ring ring-2"></div>
                <div class="ring ring-3"></div>
                <div class="success-icon">&#x2713;</div>
            </div>
            <h2 class="success-title">Dodano @addedName!</h2>
            <p class="success-sub">Profil zwierzaka jest gotowy</p>
            <button class="btn-primary" @onclick="GoToProfile">Przejdź do profilu</button>
        </div>
    }
    else
    {
        <div class="form-wrap">
            <div class="field">
                <label class="field-label">Imię <span class="required">*</span></label>
                <input type="text" class="glass-input" @bind="name" placeholder="np. Ozzy" />
            </div>

            <div class="field">
                <label class="field-label">Gatunek <span class="required">*</span></label>
                <div class="chips">
                    @foreach (var s in Enum.GetValues<VetMed.Shared.Enums.Species>())
                    {
                        var sv = s;
                        <button class="chip @(species == sv ? "chip-active" : "")" @onclick="() => species = sv" @key="sv">
                            @SpeciesEmoji(sv) @SpeciesLabel(sv)
                        </button>
                    }
                </div>
            </div>

            <div class="field">
                <label class="field-label">Rasa</label>
                <input type="text" class="glass-input" @bind="breed" placeholder="np. Labrador" />
            </div>

            <div class="field">
                <label class="field-label">Waga (kg)</label>
                <input type="number" class="glass-input" @bind="weight" placeholder="np. 4.5" min="0" max="200" step="0.1" />
            </div>

            <div class="field">
                <label class="field-label">Data urodzin <span class="required">*</span></label>
                <input type="date" class="glass-input" @bind="born" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="error-msg">@error</div>
            }

            <button class="btn-primary" @onclick="SubmitAsync" disabled="@(loading || string.IsNullOrWhiteSpace(name))">
                @(loading ? "Dodawanie..." : "Dodaj zwierzaka")
            </button>
        </div>
    }
</div>

@code {
    private string name = "";
    private VetMed.Shared.Enums.Species? species;
    private string? breed;
    private decimal? weight;
    private DateTime born = DateTime.Today.AddYears(-1);
    private string? error;
    private bool loading;
    private bool success;
    private string addedName = "";
    private int addedId;

    private async Task SubmitAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(name))
        {
            error = "Podaj imię zwierzaka.";
            return;
        }
        if (species is null)
        {
            error = "Wybierz gatunek.";
            return;
        }

        loading = true;
        try
        {
            var dto = new CreatePetDto(
                name.Trim(),
                species.Value,
                string.IsNullOrWhiteSpace(breed) ? null : breed.Trim(),
                weight,
                DateOnly.FromDateTime(born),
                null);

            var result = await PetApi.CreatePetAsync(dto);
            if (result is null)
            {
                error = Api.LastError ?? "Nie udało się dodać zwierzaka. Spróbuj ponownie.";
                return;
            }
            addedName = result.Name;
            addedId = result.Id;
            success = true;
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            loading = false;
        }
    }

    private void GoToProfile() => Nav.NavigateTo($"/pets/{addedId}");

    private static string SpeciesEmoji(VetMed.Shared.Enums.Species s) => s switch
    {
        VetMed.Shared.Enums.Species.Kot    => "🐱",
        VetMed.Shared.Enums.Species.Pies   => "🐶",
        VetMed.Shared.Enums.Species.Krolik => "🐰",
        VetMed.Shared.Enums.Species.Ptak   => "🐦",
        _                                  => "🐾"
    };

    private static string SpeciesLabel(VetMed.Shared.Enums.Species s) => s switch
    {
        VetMed.Shared.Enums.Species.Pies   => "Pies",
        VetMed.Shared.Enums.Species.Kot    => "Kot",
        VetMed.Shared.Enums.Species.Krolik => "Królik",
        VetMed.Shared.Enums.Species.Ptak   => "Ptak",
        _                                  => "Inne"
    };
}

<style>
    .add-pet-page {
        padding: 20px 16px 32px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
        padding-top: 8px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: rgba(26,44,34,0.07);
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 12px;
        color: #1A2C22;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s;
    }

    .back-btn:hover { background: rgba(60,184,122,0.1); }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: #1A2C22;
    }

    .page-sub {
        font-size: 12px;
        color: rgba(26,44,34,0.45);
        margin-top: 2px;
    }

    .form-wrap {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .field-label {
        font-size: 13px;
        font-weight: 600;
        color: rgba(26,44,34,0.6);
    }

    .required { color: var(--danger); }

    .glass-input {
        width: 100%;
        background: rgba(26,44,34,0.07);
        border: 1px solid rgba(60,184,122,0.2);
        color: #1A2C22;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }

    .glass-input:focus { border-color: rgba(60,184,122,0.6); }
    .glass-input::placeholder { color: rgba(26,44,34,0.25); }

    .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .chip {
        background: rgba(26,44,34,0.06);
        border: 1px solid rgba(60,184,122,0.2);
        color: rgba(26,44,34,0.6);
        border-radius: 20px;
        padding: 9px 16px;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
    }

    .chip-active {
        background: rgba(60,184,122,0.18);
        border-color: #3CB87A;
        color: #3CB87A;
        font-weight: 700;
    }

    .error-msg {
        background: rgba(255,112,112,0.1);
        border: 1px solid rgba(255,112,112,0.3);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        color: #FF7070;
    }

    .btn-primary {
        background: #3CB87A;
        color: #F8FCF9;
        border: none;
        border-radius: 16px;
        padding: 15px;
        font-weight: 800;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 4px;
    }

    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-primary:active:not(:disabled) { transform: scale(0.98); }

    .success-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        gap: 16px;
        text-align: center;
        flex: 1;
    }

    .success-rings {
        position: relative;
        width: 120px;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
    }

    .ring {
        position: absolute;
        border-radius: 50%;
        border: 2px solid rgba(60,184,122,0.3);
        animation: pulse-ring 2s ease-out infinite;
    }

    .ring-1 { width: 120px; height: 120px; animation-delay: 0s; }
    .ring-2 { width: 90px; height: 90px; animation-delay: 0.4s; }
    .ring-3 { width: 60px; height: 60px; animation-delay: 0.8s; }

    @@keyframes pulse-ring {
        0%   { transform: scale(0.9); opacity: 0.8; }
        100% { transform: scale(1.1); opacity: 0; }
    }

    .success-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #3CB87A;
        color: #F8FCF9;
        font-size: 26px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
    }

    .success-title {
        font-size: 24px;
        font-weight: 800;
        color: #1A2C22;
    }

    .success-sub {
        font-size: 14px;
        color: rgba(26,44,34,0.45);
    }
</style>
