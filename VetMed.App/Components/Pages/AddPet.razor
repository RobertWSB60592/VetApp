@page "/pets/add"
@using Microsoft.Maui.Media
@using Microsoft.Maui.Storage
@inject IPetApiService PetApi
@inject ApiClient Api
@inject NavigationManager Nav

<div class="add-pet-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/pets")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div>
            <div class="page-title">Dodaj zwierzaka</div>
            <div class="page-sub">Uzupełnij profil pupila</div>
        </div>
    </div>

    @if (success)
    {
        <div class="success-screen">
            <div class="success-rings">
                <div class="ring ring-1"></div>
                <div class="ring ring-2"></div>
                <div class="ring ring-3"></div>
                <div class="success-icon">&#x2713;</div>
            </div>
            <h2 class="success-title">Dodano @addedName!</h2>
            <p class="success-sub">Profil zwierzaka jest gotowy</p>
            <button class="btn-primary" @onclick="GoToProfile">Przejdź do profilu</button>
        </div>
    }
    else
    {
        <div class="form-wrap">
            <div class="photo-field">
                <button class="photo-circle" @onclick="PickPhotoAsync">
                    @if (!string.IsNullOrEmpty(imageData))
                    {
                        <img class="photo-preview" src="@imageData" alt="zdjęcie" />
                    }
                    else
                    {
                        <span class="photo-plus">＋</span>
                    }
                </button>
                <span class="photo-label">@(string.IsNullOrEmpty(imageData) ? "Dodaj zdjęcie" : "Zmień zdjęcie")</span>
            </div>

            <div class="field">
                <label class="field-label">Imię <span class="required">*</span></label>
                <input type="text" class="glass-input" @bind="name" placeholder="np. Ozzy" />
            </div>

            <div class="field">
                <label class="field-label">Gatunek <span class="required">*</span></label>
                <input type="text" class="glass-input" list="species-list" @bind="species" placeholder="np. Pies" />
                <datalist id="species-list">
                    @foreach (var s in speciesSuggestions)
                    {
                        <option value="@s" />
                    }
                </datalist>
            </div>

            <div class="field">
                <label class="field-label">Płeć</label>
                <div class="chips">
                    @foreach (var s in sexes)
                    {
                        var sv = s;
                        <button class="chip @(sex == sv ? "chip-active" : "")" @onclick="() => sex = sv" @key="sv">@SexLabel(sv)</button>
                    }
                </div>
            </div>

            <label class="toggle-row">
                <span class="field-label">Sterylizacja / kastracja</span>
                <input type="checkbox" class="toggle" @bind="sterilized" />
            </label>

            <div class="field">
                <label class="field-label">Rasa</label>
                <input type="text" class="glass-input" @bind="breed" placeholder="np. Labrador" />
            </div>

            <div class="field">
                <label class="field-label">Kolor / umaszczenie</label>
                <input type="text" class="glass-input" @bind="color" placeholder="np. czarno-biały" />
            </div>

            <div class="field">
                <label class="field-label">Waga (kg)</label>
                <input type="number" class="glass-input" @bind="weight" placeholder="np. 4.5" min="0" max="200" step="0.1" />
            </div>

            <div class="field">
                <label class="field-label">Data urodzin <span class="required">*</span></label>
                <input type="date" class="glass-input" @bind="born" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            <div class="field">
                <label class="field-label">Nr mikrochipa</label>
                <input type="text" class="glass-input" @bind="microchip" placeholder="15 cyfr" />
            </div>

            <div class="field">
                <label class="field-label">Uwagi / alergie</label>
                <textarea class="glass-input glass-textarea" @bind="notes" placeholder="np. uczulenie na kurczaka" rows="3"></textarea>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="error-msg">@error</div>
            }

            <button class="btn-primary" @onclick="SubmitAsync" disabled="@(loading || string.IsNullOrWhiteSpace(name))">
                @(loading ? "Dodawanie..." : "Dodaj zwierzaka")
            </button>
        </div>
    }
</div>

@code {
    private string name = "";
    private string species = "";
    private string? breed;
    private string? color;
    private decimal? weight;
    private DateTime born = DateTime.Today.AddYears(-1);
    private VetMed.Shared.Enums.PetSex sex = VetMed.Shared.Enums.PetSex.Nieznana;
    private bool sterilized;
    private string? microchip;
    private string? notes;
    private string? imageData;
    private string? error;
    private bool loading;
    private bool success;
    private string addedName = "";
    private int addedId;

    private static readonly string[] speciesSuggestions =
    {
        "Pies", "Kot", "Królik", "Ptak", "Chomik", "Świnka morska", "Fretka", "Żółw", "Ryba", "Koń", "Inne"
    };

    private static readonly VetMed.Shared.Enums.PetSex[] sexes =
    {
        VetMed.Shared.Enums.PetSex.Samiec, VetMed.Shared.Enums.PetSex.Samica, VetMed.Shared.Enums.PetSex.Nieznana
    };

    private async Task PickPhotoAsync()
    {
        error = null;
        try
        {
            var photo = await MediaPicker.Default.PickPhotoAsync();
            if (photo is null)
                return;

            using var stream = await photo.OpenReadAsync();
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var ext = Path.GetExtension(photo.FileName).TrimStart('.').ToLowerInvariant();
            var mime = ext == "png" ? "image/png" : "image/jpeg";
            imageData = $"data:{mime};base64,{Convert.ToBase64String(ms.ToArray())}";
        }
        catch
        {
            error = "Nie udało się wczytać zdjęcia.";
        }
    }

    private async Task SubmitAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(name))
        {
            error = "Podaj imię zwierzaka.";
            return;
        }
        if (string.IsNullOrWhiteSpace(species))
        {
            error = "Podaj gatunek.";
            return;
        }

        loading = true;
        try
        {
            var dto = new CreatePetDto(
                name.Trim(),
                species.Trim(),
                string.IsNullOrWhiteSpace(breed) ? null : breed.Trim(),
                weight,
                DateOnly.FromDateTime(born),
                imageData,
                sex,
                sterilized,
                string.IsNullOrWhiteSpace(microchip) ? null : microchip.Trim(),
                string.IsNullOrWhiteSpace(color) ? null : color.Trim(),
                string.IsNullOrWhiteSpace(notes) ? null : notes.Trim());

            var result = await PetApi.CreatePetAsync(dto);
            if (result is null)
            {
                error = Api.LastError ?? "Nie udało się dodać zwierzaka. Spróbuj ponownie.";
                return;
            }
            addedName = result.Name;
            addedId = result.Id;
            success = true;
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            loading = false;
        }
    }

    private void GoToProfile() => Nav.NavigateTo($"/pets/{addedId}");

    private static string SexLabel(VetMed.Shared.Enums.PetSex s) => s switch
    {
        VetMed.Shared.Enums.PetSex.Samiec => "Samiec",
        VetMed.Shared.Enums.PetSex.Samica => "Samica",
        _                                 => "Nieznana"
    };
}

<style>
    .add-pet-page {
        padding: 20px 16px 32px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
        padding-top: 8px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s;
    }

    .back-btn:hover { background: var(--mintGlow); }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: var(--text);
    }

    .page-sub {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    .form-wrap {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .field-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--textSub);
    }

    .required { color: var(--danger); }

    .glass-input {
        width: 100%;
        background: var(--inputBg);
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }

    .glass-input:focus { border-color: var(--mint); }
    .glass-input::placeholder { color: var(--muted); }

    .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .chip {
        background: var(--inputBg);
        border: 1px solid var(--border);
        color: var(--textSub);
        border-radius: 20px;
        padding: 9px 16px;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
    }

    .chip-active {
        background: var(--mintGlow);
        border-color: var(--mint);
        color: var(--mint);
        font-weight: 700;
    }

    .photo-field {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .photo-circle {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: var(--mintGlow);
        border: 2px dashed var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        padding: 0;
    }

    .photo-preview { width: 100%; height: 100%; object-fit: cover; }
    .photo-plus { font-size: 34px; color: var(--mint); line-height: 1; }
    .photo-label { font-size: 12px; color: var(--muted); }

    .glass-textarea { resize: vertical; min-height: 70px; }

    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
    }

    .toggle { width: 20px; height: 20px; accent-color: var(--mint); cursor: pointer; }

    .error-msg {
        background: var(--dangerBg);
        border: 1px solid var(--danger);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        color: var(--danger);
    }

    .btn-primary {
        background: var(--mint);
        color: var(--onMint);
        border: none;
        border-radius: 16px;
        padding: 15px;
        font-weight: 800;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 4px;
    }

    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-primary:active:not(:disabled) { transform: scale(0.98); }

    .success-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        gap: 16px;
        text-align: center;
        flex: 1;
    }

    .success-rings {
        position: relative;
        width: 120px;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
    }

    .ring {
        position: absolute;
        border-radius: 50%;
        border: 2px solid var(--border);
        animation: pulse-ring 2s ease-out infinite;
    }

    .ring-1 { width: 120px; height: 120px; animation-delay: 0s; }
    .ring-2 { width: 90px; height: 90px; animation-delay: 0.4s; }
    .ring-3 { width: 60px; height: 60px; animation-delay: 0.8s; }

    @@keyframes pulse-ring {
        0%   { transform: scale(0.9); opacity: 0.8; }
        100% { transform: scale(1.1); opacity: 0; }
    }

    .success-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--mint);
        color: var(--onMint);
        font-size: 26px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
    }

    .success-title {
        font-size: 24px;
        font-weight: 800;
        color: var(--text);
    }

    .success-sub {
        font-size: 14px;
        color: var(--muted);
    }
</style>
