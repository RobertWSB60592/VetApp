@page "/clinic"
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.ApplicationModel.Communication
@inject NavigationManager Nav

<div class="clinic-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div>
            <div class="page-title">Przychodnia</div>
            <div class="page-sub">@ClinicInfo.FullName</div>
        </div>
    </div>

    <div class="hero-card">
        <div class="hero-logo">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <path d="M20 3L4 10v11c0 9 7 14 16 15 9-1 16-6 16-15V10L20 3Z" style="fill:var(--mintGlow);stroke:var(--mint)" stroke-width="1.5"/>
                <rect x="17.5" y="12" width="5" height="16" rx="2.5" style="fill:var(--mint)"/>
                <rect x="12" y="17.5" width="16" height="5" rx="2.5" style="fill:var(--mint)"/>
            </svg>
        </div>
        <div class="hero-name">@ClinicInfo.FullName</div>
        <div class="hero-addr">@ClinicInfo.Address</div>
    </div>

    <div class="info-card">
        <div class="info-row">
            <div class="row-icon">&#x1F4CD;</div>
            <div class="row-text"><span class="row-label">Adres</span><span class="row-value">@ClinicInfo.Address</span></div>
        </div>
        <div class="info-row">
            <div class="row-icon">&#x1F552;</div>
            <div class="row-text"><span class="row-label">Pon–Pt</span><span class="row-value">@ClinicInfo.HoursWeekday</span></div>
        </div>
        <div class="info-row">
            <div class="row-icon">&#x1F552;</div>
            <div class="row-text"><span class="row-label">Sobota</span><span class="row-value">@ClinicInfo.HoursSaturday</span></div>
        </div>
        <div class="info-row">
            <div class="row-icon">&#x1F512;</div>
            <div class="row-text"><span class="row-label">Niedziela</span><span class="row-value">@ClinicInfo.HoursSunday</span></div>
        </div>
        <div class="info-row">
            <div class="row-icon">&#x1F4DE;</div>
            <div class="row-text"><span class="row-label">Telefon</span><span class="row-value">@ClinicInfo.Phone</span></div>
        </div>
        <div class="info-row">
            <div class="row-icon">&#x1F4E7;</div>
            <div class="row-text"><span class="row-label">Email</span><span class="row-value">@ClinicInfo.Email</span></div>
        </div>
    </div>

    <button class="action-card" @onclick="OpenMaps">
        <div class="action-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>
            </svg>
        </div>
        <div class="action-text">
            <span class="action-title">Otwórz w Google Maps</span>
            <span class="action-sub">Nawigacja krok po kroku</span>
        </div>
        <span class="action-go">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </span>
    </button>

    <button class="action-card" @onclick="CallClinic">
        <div class="action-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
        </div>
        <div class="action-text">
            <span class="action-title">Zadzwoń teraz</span>
            <span class="action-sub">@ClinicInfo.Phone</span>
        </div>
    </button>

    <button class="action-card" @onclick="EmailClinic">
        <div class="action-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,6 12,13 2,6"/>
            </svg>
        </div>
        <div class="action-text">
            <span class="action-title">Napisz e-mail</span>
            <span class="action-sub">@ClinicInfo.Email</span>
        </div>
    </button>
</div>

@code {
    private async Task OpenMaps()
    {
        try { await Launcher.Default.OpenAsync(new Uri(ClinicInfo.MapsUrl)); }
        catch { }
    }

    private void CallClinic()
    {
        try
        {
            if (PhoneDialer.Default.IsSupported)
                PhoneDialer.Default.Open(ClinicInfo.PhoneDial);
        }
        catch { }
    }

    private async Task EmailClinic()
    {
        try
        {
            if (Email.Default.IsComposeSupported)
                await Email.Default.ComposeAsync(new EmailMessage { To = { ClinicInfo.Email } });
        }
        catch { }
    }
}

<style>
    .clinic-page {
        padding: 20px 16px 32px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding-top: 8px;
        margin-bottom: 4px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
    }

    .page-title { font-size: 20px; font-weight: 800; color: var(--text); }
    .page-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

    .hero-card {
        background: linear-gradient(135deg, var(--mintGlow), transparent);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: var(--cardShadow);
        padding: 22px 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 4px;
    }

    .hero-logo {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        background: var(--mintGlow);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
    }

    .hero-name { font-size: 18px; font-weight: 800; color: var(--text); }
    .hero-addr { font-size: 12px; color: var(--muted); }

    .info-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--cardShadow);
        overflow: hidden;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 16px;
        border-bottom: 1px solid var(--faint);
    }

    .info-row:last-child { border-bottom: none; }

    .row-icon {
        width: 34px;
        height: 34px;
        border-radius: 11px;
        background: var(--mintGlow);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }

    .row-text { display: flex; flex-direction: column; }
    .row-label { font-size: 10px; font-weight: 700; letter-spacing: 0.3px; color: var(--muted); text-transform: uppercase; }
    .row-value { font-size: 13px; font-weight: 500; color: var(--text); }

    .action-card {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        text-align: left;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--cardShadow);
        padding: 14px 16px;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: transform 0.12s, border-color 0.2s;
    }

    .action-card:active { transform: scale(0.99); border-color: var(--mint); }

    .action-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: var(--mintGlow);
        border: 1px solid var(--border);
        color: var(--mint);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .action-text { flex: 1; display: flex; flex-direction: column; gap: 1px; }
    .action-title { font-size: 14px; font-weight: 700; color: var(--mint); }
    .action-sub { font-size: 11px; color: var(--muted); }
    .action-go { color: var(--mint); display: flex; flex-shrink: 0; }
</style>
