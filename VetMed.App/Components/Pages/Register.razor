@page "/register"
@layout AuthLayout
@inject IAuthApiService AuthApi
@inject AppState AppState
@inject NavigationManager Nav

<div class="login-page">
    <div class="logo-wrap">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M26 4L6 13v14c0 11.05 8.55 21.38 20 23.93C37.45 48.38 46 38.05 46 27V13L26 4z" fill="rgba(111,207,176,0.15)" stroke="#6FCFB0" stroke-width="2"/>
            <path d="M20 24h4v-4a2 2 0 1 1 4 0v4h4a2 2 0 1 1 0 4h-4v4a2 2 0 1 1-4 0v-4h-4a2 2 0 1 1 0-4z" fill="#6FCFB0"/>
        </svg>
        <span class="logo-text">VetMed</span>
    </div>

    <h1 class="page-title">Utwórz konto</h1>
    <p class="page-sub">Dołącz do VetMed już dziś</p>

    <div class="card">
        <div class="field">
            <label>Imię i nazwisko</label>
            <input type="text" @bind="fullName" placeholder="Jan Kowalski" autocomplete="name" />
        </div>
        <div class="field">
            <label>Email</label>
            <input type="email" @bind="email" placeholder="twoj@email.pl" autocomplete="email" />
        </div>
        <div class="field">
            <label>Hasło</label>
            <input type="password" @bind="password" placeholder="Min. 6 znaków" autocomplete="new-password" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error-msg">@error</div>
        }

        <button class="btn-primary" @onclick="RegisterAsync" disabled="@loading">
            @if (loading)
            {
                <span>Rejestracja...</span>
            }
            else
            {
                <span>Zarejestruj się</span>
            }
        </button>
    </div>

    <div class="footer-link">
        Masz już konto?
        <a href="/login">Zaloguj się</a>
    </div>
</div>

@code {
    private string fullName = "";
    private string email = "";
    private string password = "";
    private string? error;
    private bool loading;

    protected override void OnInitialized()
    {
        if (AppState.IsAuthenticated)
            Nav.NavigateTo("/", replace: true);
    }

    private async Task RegisterAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            error = "Wypełnij wszystkie pola.";
            return;
        }
        if (password.Length < 6)
        {
            error = "Hasło musi mieć co najmniej 6 znaków.";
            return;
        }

        loading = true;
        try
        {
            var result = await AuthApi.RegisterAsync(new RegisterDto(fullName, email, password));
            if (result is null)
            {
                error = "Rejestracja nie powiodła się. Spróbuj ponownie.";
                return;
            }
            AppState.SetAuth(result);
            Nav.NavigateTo("/", replace: true);
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            loading = false;
        }
    }
}

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 24px;
        background: #0D1F1C;
    }

    .logo-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
    }

    .logo-text {
        font-size: 28px;
        font-weight: 800;
        color: #6FCFB0;
        letter-spacing: -0.5px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #E8F5F2;
        margin-bottom: 6px;
        text-align: center;
    }

    .page-sub {
        font-size: 14px;
        color: rgba(232,245,242,0.6);
        margin-bottom: 28px;
        text-align: center;
    }

    .card {
        width: 100%;
        max-width: 380px;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(111,207,176,0.2);
        border-radius: 20px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field label {
        font-size: 13px;
        font-weight: 600;
        color: rgba(232,245,242,0.7);
    }

    .field input {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(111,207,176,0.2);
        color: #E8F5F2;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
    }

    .field input:focus { border-color: rgba(111,207,176,0.6); }
    .field input::placeholder { color: rgba(232,245,242,0.3); }

    .error-msg {
        background: rgba(255,80,80,0.12);
        border: 1px solid rgba(255,80,80,0.3);
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 13px;
        color: #ff8080;
    }

    .btn-primary {
        background: #6FCFB0;
        color: #0D1F1C;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        font-size: 15px;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 4px;
    }

    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-primary:active:not(:disabled) { transform: scale(0.98); }

    .footer-link {
        margin-top: 24px;
        font-size: 14px;
        color: rgba(232,245,242,0.6);
    }

    .footer-link a {
        color: #6FCFB0;
        font-weight: 600;
        text-decoration: none;
        margin-left: 4px;
    }
</style>
