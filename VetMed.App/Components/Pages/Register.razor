@page "/register"
@layout AuthLayout
@inject IAuthApiService AuthApi
@inject AppState AppState
@inject NavigationManager Nav

<div class="register-page">
    <div class="login-glow"></div>

    <div class="back-header">
        <a href="/login" class="back-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </a>
        <div class="header-titles">
            <div class="header-title">Utwórz konto</div>
            <div class="header-sub">Dołącz do VetMed już dziś</div>
        </div>
    </div>

    <div class="logo-mark">
        <svg width="48" height="48" viewBox="0 0 40 40" fill="none">
            <path d="M20 3L4 10v11c0 9 7 14 16 15 9-1 16-6 16-15V10L20 3Z" style="fill:var(--mintGlow);stroke:var(--mint)" stroke-width="1.5"/>
            <rect x="17.5" y="12" width="5" height="16" rx="2.5" style="fill:var(--mint)"/>
            <rect x="12" y="17.5" width="16" height="5" rx="2.5" style="fill:var(--mint)"/>
        </svg>
    </div>

    <div class="form-area">
        <div class="field">
            <label class="field-label">Imię i nazwisko</label>
            <input type="text" class="glass-input" @bind="fullName" placeholder="Jan Kowalski" autocomplete="name" />
        </div>
        <div class="field">
            <label class="field-label">Email</label>
            <input type="email" class="glass-input" @bind="email" placeholder="twoj@email.pl" autocomplete="email" />
        </div>
        <div class="field">
            <label class="field-label">Hasło</label>
            <input type="password" class="glass-input" @bind="password" placeholder="Min. 6 znaków" autocomplete="new-password" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error-msg">@error</div>
        }

        <button class="btn-primary" @onclick="RegisterAsync" disabled="@loading">
            @(loading ? "Rejestracja..." : "Zarejestruj się")
        </button>

        <div class="footer-link">
            Masz już konto?
            <a href="/login" class="footer-a">Zaloguj się</a>
        </div>
    </div>
</div>

@code {
    private string fullName = "";
    private string email = "";
    private string password = "";
    private string? error;
    private bool loading;

    protected override void OnInitialized()
    {
        if (AppState.IsAuthenticated)
            Nav.NavigateTo("/", replace: true);
    }

    private async Task RegisterAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            error = "Wypełnij wszystkie pola.";
            return;
        }
        if (password.Length < 6)
        {
            error = "Hasło musi mieć co najmniej 6 znaków.";
            return;
        }

        loading = true;
        try
        {
            var result = await AuthApi.RegisterAsync(new RegisterDto(fullName, email, password));
            if (result is null)
            {
                error = "Rejestracja nie powiodła się. Spróbuj ponownie.";
                return;
            }
            AppState.SetAuth(result);
            Nav.NavigateTo("/", replace: true);
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            loading = false;
        }
    }
}

<style>
    .register-page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        background: transparent;
        padding: 0 24px 40px;
        position: relative;
        overflow: hidden;
    }

    .login-glow {
        position: absolute;
        top: -80px;
        right: -80px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, var(--mintGlow) 0%, transparent 70%);
        pointer-events: none;
    }

    .back-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding-top: 56px;
        margin-bottom: 32px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text);
        text-decoration: none;
        flex-shrink: 0;
        transition: background 0.2s;
    }

    .back-btn:hover { background: var(--mintGlow); }

    .header-title {
        font-size: 20px;
        font-weight: 800;
        color: var(--text);
    }

    .header-sub {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    .logo-mark {
        display: flex;
        justify-content: center;
        margin-bottom: 32px;
    }

    .form-area {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--textSub);
    }

    .glass-input {
        width: 100%;
        background: var(--inputBg);
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }

    .glass-input:focus { border-color: var(--mint); }
    .glass-input::placeholder { color: var(--muted); }

    .error-msg {
        background: var(--dangerBg);
        border: 1px solid var(--danger);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        color: var(--danger);
    }

    .btn-primary {
        width: 100%;
        background: var(--mint);
        color: var(--onMint);
        border: none;
        border-radius: 16px;
        padding: 15px;
        font-weight: 800;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 4px;
    }

    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-primary:active:not(:disabled) { transform: scale(0.98); }

    .footer-link {
        text-align: center;
        font-size: 14px;
        color: var(--muted);
        padding-top: 8px;
    }

    .footer-a {
        color: var(--mint);
        font-weight: 700;
        text-decoration: none;
        margin-left: 4px;
    }
</style>
