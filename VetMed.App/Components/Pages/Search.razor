@page "/search"
@inject IPetApiService PetApi
@inject IVisitApiService VisitApi
@inject NavigationManager Nav

<div class="search-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div class="search-box">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input class="search-input" placeholder="Szukaj zwierzaka, wizyty, lekarza..."
                   @bind="query" @bind:event="oninput" autofocus />
            @if (!string.IsNullOrEmpty(query))
            {
                <button class="clear-btn" @onclick="Clear">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            }
        </div>
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else if (string.IsNullOrWhiteSpace(query))
    {
        <div class="hint-state">
            <span class="hint-icon">&#x1F50D;</span>
            <p class="hint-title">Czego szukasz?</p>
            <p class="hint-sub">Wpisz imię zwierzaka, typ wizyty albo nazwisko lekarza.</p>
        </div>
    }
    else if (matchedPets.Count == 0 && matchedVisits.Count == 0)
    {
        <div class="hint-state">
            <span class="hint-icon">&#x1F43E;</span>
            <p class="hint-title">Brak wyników</p>
            <p class="hint-sub">Nie znaleziono nic dla „@query".</p>
        </div>
    }
    else
    {
        @if (matchedPets.Count > 0)
        {
            <div class="section-label">Zwierzaki (@matchedPets.Count)</div>
            <div class="result-list">
                @foreach (var p in matchedPets)
                {
                    var pid = p.Id;
                    <button class="result-row" @onclick='() => Nav.NavigateTo($"/pets/{pid}")' @key="p.Id">
                        <span class="result-emoji">@PetVisuals.Emoji(p.Species)</span>
                        <span class="result-body">
                            <span class="result-title">@p.Name</span>
                            <span class="result-sub">@p.Species@(string.IsNullOrEmpty(p.Breed) ? "" : " · " + p.Breed)</span>
                        </span>
                        <span class="result-chev">›</span>
                    </button>
                }
            </div>
        }

        @if (matchedVisits.Count > 0)
        {
            <div class="section-label">Wizyty (@matchedVisits.Count)</div>
            <div class="result-list">
                @foreach (var v in matchedVisits)
                {
                    var vid = v.Id;
                    <button class="result-row" @onclick='() => Nav.NavigateTo($"/visits/{vid}")' @key="v.Id">
                        <span class="result-dot" style="background:@VisitColor(v.Type)"></span>
                        <span class="result-body">
                            <span class="result-title">@VisitLabel(v.Type) — @v.PetName</span>
                            <span class="result-sub">@v.ScheduledAt.ToString("dd.MM.yyyy") · @v.DoctorName</span>
                        </span>
                        <span class="result-chev">›</span>
                    </button>
                }
            </div>
        }
    }
</div>

@code {
    private string query = "";
    private bool loading = true;
    private List<PetDto> pets = new();
    private List<VisitDto> visits = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pTask = PetApi.GetPetsAsync();
            var vTask = VisitApi.GetVisitsAsync();
            await Task.WhenAll(pTask, vTask);
            pets = pTask.Result;
            visits = vTask.Result.OrderByDescending(v => v.ScheduledAt).ToList();
        }
        catch { }
        finally { loading = false; }
    }

    private void Clear() => query = "";

    private List<PetDto> matchedPets => string.IsNullOrWhiteSpace(query)
        ? new()
        : pets.Where(p => Contains(p.Name) || Contains(p.Species) || Contains(p.Breed)).ToList();

    private List<VisitDto> matchedVisits => string.IsNullOrWhiteSpace(query)
        ? new()
        : visits.Where(v => Contains(v.PetName) || Contains(v.DoctorName) || Contains(v.Notes) || Contains(VisitLabel(v.Type))).ToList();

    private bool Contains(string? value) =>
        !string.IsNullOrEmpty(value) && value.Contains(query.Trim(), StringComparison.OrdinalIgnoreCase);

    private static string VisitColor(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "var(--vSzczep)",
        VetMed.Shared.Enums.VisitType.Zabieg      => "var(--vZabieg)",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "var(--vDiag)",
        VetMed.Shared.Enums.VisitType.Nagly       => "var(--danger)",
        _                                          => "var(--vWizyta)"
    };

    private static string VisitLabel(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "Szczepienie",
        VetMed.Shared.Enums.VisitType.Kontrola    => "Kontrola",
        VetMed.Shared.Enums.VisitType.Zabieg      => "Zabieg",
        VetMed.Shared.Enums.VisitType.Nagly       => "Nagły",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "Diagnostyka",
        _                                          => t.ToString()
    };
}

<style>
    .search-page { padding: 20px 16px 8px; display: flex; flex-direction: column; }

    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-top: 8px;
        margin-bottom: 18px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
    }

    .search-box {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 0 12px;
        color: var(--muted);
    }

    .search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text);
        font-size: 14px;
        padding: 12px 0;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .search-input::placeholder { color: var(--muted); }

    .clear-btn {
        background: transparent;
        border: none;
        color: var(--muted);
        display: flex;
        cursor: pointer;
        padding: 2px;
    }

    .section-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin: 14px 4px 10px;
    }

    .result-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 6px; }

    .result-row {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        text-align: left;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 12px 14px;
        box-shadow: var(--cardShadow);
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: transform 0.12s, border-color 0.2s;
    }

    .result-row:active { transform: scale(0.99); border-color: var(--mint); }

    .result-emoji {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--mintGlow);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .result-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 8px currentColor;
    }

    .result-body { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .result-title { font-size: 14px; font-weight: 700; color: var(--text); }
    .result-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }
    .result-chev { color: var(--muted); font-size: 20px; flex-shrink: 0; line-height: 1; }

    .hint-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 64px 24px;
        text-align: center;
    }

    .hint-icon { font-size: 44px; }
    .hint-title { font-size: 16px; font-weight: 700; color: var(--text); }
    .hint-sub { font-size: 13px; color: var(--muted); }
</style>
