@page "/pets"
@inject IPetApiService PetApi
@inject NavigationManager Nav

<div class="pets-page">
    <div class="page-header">
        <h1 class="page-title">Twoje zwierzaki</h1>
        <button class="header-add-btn" @onclick='() => Nav.NavigateTo("/pets/add")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
        </button>
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="pets-grid">
            @foreach (var pet in pets)
            {
                var petId = pet.Id;
                <div class="grid-card" @onclick="() => Nav.NavigateTo(PetRoute(petId))" @key="pet.Id">
                    <div class="card-top">
                        @if (!string.IsNullOrEmpty(pet.ImageUrl))
                        {
                            <img class="card-photo" src="@pet.ImageUrl" alt="@pet.Name" />
                        }
                        else
                        {
                            <div class="card-emoji">@PetVisuals.Emoji(pet.Species)</div>
                        }
                        <div class="card-age-badge">@PetAge(pet.Born)</div>
                    </div>
                    <div class="card-body">
                        <div class="card-name">@pet.Name</div>
                        @if (!string.IsNullOrEmpty(pet.Breed))
                        {
                            <div class="card-breed">@pet.Breed</div>
                        }
                        <div class="card-tags">
                            @if (pet.WeightKg.HasValue)
                            {
                                <span class="tag">@pet.WeightKg kg</span>
                            }
                            <span class="tag tag-mint">@pet.Species</span>
                        </div>
                        @if (pendingDeleteId == petId)
                        {
                            <div class="card-actions">
                                <span class="confirm-text">Usunąć?</span>
                                <button class="act-btn act-danger" @onclick="() => ArchiveAsync(petId)" @onclick:stopPropagation="true">Tak</button>
                                <button class="act-btn" @onclick="() => pendingDeleteId = null" @onclick:stopPropagation="true">Nie</button>
                            </div>
                        }
                        else
                        {
                            <div class="card-actions">
                                <button class="act-btn" @onclick='() => Nav.NavigateTo($"/pets/{petId}/edit")' @onclick:stopPropagation="true">Edytuj</button>
                                <button class="act-btn act-danger" @onclick="() => pendingDeleteId = petId" @onclick:stopPropagation="true">Usuń</button>
                            </div>
                        }
                    </div>
                </div>
            }
            <div class="grid-card grid-add" @onclick='() => Nav.NavigateTo("/pets/add")'>
                <div class="add-plus">+</div>
                <div class="add-label">Dodaj zwierzaka</div>
            </div>
        </div>
    }
</div>

@code {
    private List<PetDto> pets = new();
    private bool loading = true;
    private int? pendingDeleteId;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try { pets = await PetApi.GetPetsAsync(); }
        catch { }
        finally { loading = false; }
    }

    private async Task ArchiveAsync(int id)
    {
        pendingDeleteId = null;
        var ok = await PetApi.DeletePetAsync(id);
        if (ok)
            pets = pets.Where(p => p.Id != id).ToList();
    }

    private static string PetRoute(int id) => $"/pets/{id}";

    private static string PetAge(DateOnly born)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - born.Year) * 12 + today.Month - born.Month;
        if (today.Day < born.Day) months--;
        if (months < 12) return $"{months} mies.";
        var years = months / 12;
        return years == 1 ? "1 rok" : $"{years} lat";
    }
}

<style>
    .pets-page {
        padding: 20px 16px 8px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 8px;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 800;
        color: #1A2C22;
    }

    .header-add-btn {
        width: 38px;
        height: 38px;
        background: rgba(60,184,122,0.15);
        border: 1px solid rgba(60,184,122,0.3);
        border-radius: 12px;
        color: #3CB87A;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
    }

    .header-add-btn:hover { background: rgba(60,184,122,0.25); }

    .pets-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .grid-card {
        background: #FFFFFF;
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.15s;
        box-shadow: 0 8px 24px rgba(26,44,34,0.08);
    }

    .grid-card:active { transform: scale(0.97); }
    .grid-card:hover { border-color: rgba(60,184,122,0.45); }

    .card-top {
        position: relative;
        background: rgba(60,184,122,0.08);
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-emoji { font-size: 44px; line-height: 1; }

    .card-photo { width: 100%; height: 100%; object-fit: cover; }

    .card-actions {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 10px;
    }

    .confirm-text { font-size: 11px; color: rgba(26,44,34,0.55); margin-right: auto; }

    .act-btn {
        flex: 1;
        background: rgba(26,44,34,0.06);
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 9px;
        padding: 6px 0;
        font-size: 12px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: rgba(26,44,34,0.7);
        cursor: pointer;
    }

    .act-danger { color: #EF5350; border-color: rgba(239,83,80,0.3); background: rgba(239,83,80,0.08); }

    .card-age-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(26,44,34,0.06);
        backdrop-filter: blur(8px);
        border-radius: 8px;
        padding: 3px 7px;
        border: 1px solid rgba(255,255,255,0.15);
        font-size: 10px;
        font-weight: 600;
        color: rgba(26,44,34,0.85);
    }

    .card-body {
        padding: 10px 12px 14px;
    }

    .card-name {
        font-size: 15px;
        font-weight: 700;
        color: #1A2C22;
    }

    .card-breed {
        font-size: 12px;
        color: rgba(26,44,34,0.45);
        margin-top: 2px;
    }

    .card-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .tag {
        font-size: 11px;
        background: rgba(26,44,34,0.08);
        border-radius: 8px;
        padding: 3px 8px;
        color: rgba(26,44,34,0.6);
    }

    .tag-mint { color: #3CB87A; background: rgba(60,184,122,0.12); }

    .grid-add {
        border-style: dashed;
        border-color: rgba(60,184,122,0.25);
        background: rgba(26,44,34,0.02);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 160px;
        gap: 8px;
    }

    .add-plus {
        font-size: 32px;
        color: rgba(60,184,122,0.5);
        line-height: 1;
    }

    .add-label {
        font-size: 12px;
        color: rgba(26,44,34,0.35);
    }
</style>
