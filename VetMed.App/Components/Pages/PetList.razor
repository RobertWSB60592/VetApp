@page "/pets"
@inject IPetApiService PetApi
@inject NavigationManager Nav

<div class="pets-page">
    <div class="page-header">
        <h1 class="page-title">Twoje zwierzaki</h1>
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="pets-grid">
            @foreach (var pet in pets)
            {
                var petId = pet.Id;
                <div class="grid-card" @onclick="() => Nav.NavigateTo(PetRoute(petId))" @key="pet.Id">
                    <div class="card-emoji">@SpeciesEmoji(pet.Species)</div>
                    <div class="card-name">@pet.Name</div>
                    @if (!string.IsNullOrEmpty(pet.Breed))
                    {
                        <div class="card-breed">@pet.Breed</div>
                    }
                    <div class="card-row">
                        @if (pet.WeightKg.HasValue)
                        {
                            <span class="tag">@pet.WeightKg kg</span>
                        }
                        <span class="tag mint">@PetAge(pet.Born)</span>
                    </div>
                </div>
            }
            <div class="grid-card add" @onclick='() => Nav.NavigateTo("/pets/add")'>
                <div class="add-plus">+</div>
                <div class="add-label">Dodaj zwierzaka</div>
            </div>
        </div>
    }
</div>

@code {
    private List<PetDto> pets = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try { pets = await PetApi.GetPetsAsync(); }
        catch { }
        finally { loading = false; }
    }

    private static string PetRoute(int id) => $"/pets/{id}";

    private static string SpeciesEmoji(VetMed.Shared.Enums.Species s) => s switch
    {
        VetMed.Shared.Enums.Species.Kot    => "🐱",
        VetMed.Shared.Enums.Species.Pies   => "🐶",
        VetMed.Shared.Enums.Species.Krolik => "🐰",
        VetMed.Shared.Enums.Species.Ptak   => "🐦",
        _                                  => "🐾"
    };

    private static string PetAge(DateOnly born)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - born.Year) * 12 + today.Month - born.Month;
        if (today.Day < born.Day) months--;
        if (months < 12) return $"{months} mies.";
        var years = months / 12;
        return years == 1 ? "1 rok" : $"{years} lat";
    }
}

<style>
    .pets-page {
        padding: 20px 16px 8px;
    }

    .page-header {
        padding-top: 8px;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 800;
        color: #E8F5F2;
    }

    .pets-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .grid-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(111,207,176,0.2);
        border-radius: 18px;
        padding: 18px 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.15s;
    }

    .grid-card:active { transform: scale(0.97); }
    .grid-card:hover { border-color: rgba(111,207,176,0.45); }

    .card-emoji { font-size: 40px; line-height: 1; margin-bottom: 4px; }

    .card-name {
        font-size: 15px;
        font-weight: 700;
        color: #E8F5F2;
    }

    .card-breed {
        font-size: 12px;
        color: rgba(232,245,242,0.55);
    }

    .card-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 4px;
    }

    .tag {
        font-size: 11px;
        background: rgba(255,255,255,0.08);
        border-radius: 8px;
        padding: 3px 8px;
        color: rgba(232,245,242,0.7);
    }

    .tag.mint { color: #6FCFB0; background: rgba(111,207,176,0.12); }

    .grid-card.add {
        border-style: dashed;
        border-color: rgba(111,207,176,0.25);
        background: rgba(255,255,255,0.03);
        justify-content: center;
        min-height: 140px;
    }

    .add-plus {
        font-size: 32px;
        color: rgba(111,207,176,0.5);
        line-height: 1;
    }

    .add-label {
        font-size: 12px;
        color: rgba(232,245,242,0.4);
    }
</style>
