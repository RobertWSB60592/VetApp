@page "/pets"
@inject IPetApiService PetApi
@inject NavigationManager Nav

<div class="pets-page">
    <div class="page-header">
        <h1 class="page-title">Twoje zwierzaki</h1>
        <button class="header-add-btn" @onclick='() => Nav.NavigateTo("/pets/add")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
        </button>
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="pets-grid">
            @foreach (var pet in pets)
            {
                var petId = pet.Id;
                <div class="grid-card" @onclick="() => Nav.NavigateTo(PetRoute(petId))" @key="pet.Id">
                    <div class="card-top">
                        <div class="card-emoji">@SpeciesEmoji(pet.Species)</div>
                        <div class="card-age-badge">@PetAge(pet.Born)</div>
                    </div>
                    <div class="card-body">
                        <div class="card-name">@pet.Name</div>
                        @if (!string.IsNullOrEmpty(pet.Breed))
                        {
                            <div class="card-breed">@pet.Breed</div>
                        }
                        <div class="card-tags">
                            @if (pet.WeightKg.HasValue)
                            {
                                <span class="tag">@pet.WeightKg kg</span>
                            }
                            <span class="tag tag-mint">@SpeciesLabel(pet.Species)</span>
                        </div>
                    </div>
                </div>
            }
            <div class="grid-card grid-add" @onclick='() => Nav.NavigateTo("/pets/add")'>
                <div class="add-plus">+</div>
                <div class="add-label">Dodaj zwierzaka</div>
            </div>
        </div>
    }
</div>

@code {
    private List<PetDto> pets = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try { pets = await PetApi.GetPetsAsync(); }
        catch { }
        finally { loading = false; }
    }

    private static string PetRoute(int id) => $"/pets/{id}";

    private static string SpeciesEmoji(VetMed.Shared.Enums.Species s) => s switch
    {
        VetMed.Shared.Enums.Species.Kot    => "🐱",
        VetMed.Shared.Enums.Species.Pies   => "🐶",
        VetMed.Shared.Enums.Species.Krolik => "🐰",
        VetMed.Shared.Enums.Species.Ptak   => "🐦",
        _                                  => "🐾"
    };

    private static string SpeciesLabel(VetMed.Shared.Enums.Species s) => s switch
    {
        VetMed.Shared.Enums.Species.Pies   => "Pies",
        VetMed.Shared.Enums.Species.Kot    => "Kot",
        VetMed.Shared.Enums.Species.Krolik => "Królik",
        VetMed.Shared.Enums.Species.Ptak   => "Ptak",
        _                                  => "Inne"
    };

    private static string PetAge(DateOnly born)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - born.Year) * 12 + today.Month - born.Month;
        if (today.Day < born.Day) months--;
        if (months < 12) return $"{months} mies.";
        var years = months / 12;
        return years == 1 ? "1 rok" : $"{years} lat";
    }
}

<style>
    .pets-page {
        padding: 20px 16px 8px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 8px;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 800;
        color: #F5EDE5;
    }

    .header-add-btn {
        width: 38px;
        height: 38px;
        background: rgba(232,144,106,0.15);
        border: 1px solid rgba(232,144,106,0.3);
        border-radius: 12px;
        color: #E8906A;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
    }

    .header-add-btn:hover { background: rgba(232,144,106,0.25); }

    .pets-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .grid-card {
        background: #352010;
        border: 1px solid rgba(232,144,106,0.2);
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.15s;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    .grid-card:active { transform: scale(0.97); }
    .grid-card:hover { border-color: rgba(232,144,106,0.45); }

    .card-top {
        position: relative;
        background: rgba(232,144,106,0.08);
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-emoji { font-size: 44px; line-height: 1; }

    .card-age-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px);
        border-radius: 8px;
        padding: 3px 7px;
        border: 1px solid rgba(255,255,255,0.15);
        font-size: 10px;
        font-weight: 600;
        color: rgba(245,237,229,0.85);
    }

    .card-body {
        padding: 10px 12px 14px;
    }

    .card-name {
        font-size: 15px;
        font-weight: 700;
        color: #F5EDE5;
    }

    .card-breed {
        font-size: 12px;
        color: rgba(245,237,229,0.45);
        margin-top: 2px;
    }

    .card-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .tag {
        font-size: 11px;
        background: rgba(245,237,229,0.08);
        border-radius: 8px;
        padding: 3px 8px;
        color: rgba(245,237,229,0.6);
    }

    .tag-mint { color: #E8906A; background: rgba(232,144,106,0.12); }

    .grid-add {
        border-style: dashed;
        border-color: rgba(232,144,106,0.25);
        background: rgba(245,237,229,0.02);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 160px;
        gap: 8px;
    }

    .add-plus {
        font-size: 32px;
        color: rgba(232,144,106,0.5);
        line-height: 1;
    }

    .add-label {
        font-size: 12px;
        color: rgba(245,237,229,0.35);
    }
</style>
