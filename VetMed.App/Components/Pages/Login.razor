@page "/login"
@layout AuthLayout
@using VetMed.Shared.DTOs
@inject IAuthApiService AuthApi
@inject ApiClient Api
@inject AppState AppState
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-glow"></div>

    <div class="logo-section">
        <div class="logo-card">
            <svg width="60" height="60" viewBox="0 0 40 40" fill="none">
                <path d="M20 3L4 10v11c0 9 7 14 16 15 9-1 16-6 16-15V10L20 3Z" fill="rgba(232,144,106,0.18)" stroke="#E8906A" stroke-width="1.5"/>
                <rect x="17.5" y="12" width="5" height="16" rx="2.5" fill="#E8906A"/>
                <rect x="12" y="17.5" width="16" height="5" rx="2.5" fill="#E8906A"/>
            </svg>
        </div>
        <div class="logo-title">VETMED</div>
        <div class="logo-sub">Opieka nad Twoimi pupilami</div>
    </div>

    <div class="login-form-area">
        <h1 class="form-heading">Witaj z powrotem</h1>
        <p class="form-sub">Zaloguj się do swojego konta</p>

        <div class="field">
            <input type="email" class="glass-input" @bind="email" placeholder="Email" autocomplete="email" />
        </div>
        <div class="field">
            <input type="password" class="glass-input" @bind="password" placeholder="Hasło" autocomplete="current-password" />
        </div>

        <div class="forgot-row">
            <a href="#" class="forgot-link">Zapomniałem hasła</a>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error-msg">@error</div>
        }

        <button class="btn-primary" @onclick="LoginAsync" disabled="@loading">
            @(loading ? "Logowanie..." : "Zaloguj się")
        </button>

        <div class="divider"><span>lub</span></div>

        <a href="/register" class="btn-secondary">Utwórz konto</a>

        <div class="quick-section">
            <div class="quick-chips">
                <button class="quick-chip" @onclick='() => QuickLogin("demo@vetmed.pl", "demo123")'>&#x1F464; Demo</button>
                <button class="quick-chip" @onclick='() => QuickLogin("test@vetmed.pl", "")'>&#x1F9EA; Test</button>
                <button class="quick-chip" @onclick='() => QuickLogin("admin@vetmed.pl", "admin123")'>&#x1F511; Admin</button>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool loading;

    protected override void OnInitialized()
    {
        if (AppState.IsAuthenticated)
            Nav.NavigateTo("/", replace: true);
    }

    private async Task QuickLogin(string quickEmail, string quickPassword)
    {
        email = quickEmail;
        password = quickPassword;
        await LoginAsync();
    }

    private async Task LoginAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Podaj adres email.";
            return;
        }

        loading = true;
        try
        {
            var result = await AuthApi.LoginAsync(new LoginDto(email, password));
            if (result is null)
            {
                error = Api.LastError is not null
                    ? $"Błąd API: {Api.LastError}"
                    : "Nieprawidłowy email lub hasło.";
                return;
            }
            AppState.SetAuth(result);
            Nav.NavigateTo("/", replace: true);
        }
        catch (Exception ex)
        {
            error = $"Błąd połączenia: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}

<style>
    .login-page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 24px 40px;
        background: #1C100A;
        position: relative;
        overflow: hidden;
    }

    .login-glow {
        position: absolute;
        top: -80px;
        right: -80px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(232,144,106,0.15) 0%, transparent 70%);
        pointer-events: none;
    }

    .logo-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 64px;
        margin-bottom: 40px;
    }

    .logo-card {
        width: 100px;
        height: 100px;
        background: rgba(232,144,106,0.1);
        border: 1px solid rgba(232,144,106,0.3);
        border-radius: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .logo-title {
        font-family: 'Josefin Slab', serif;
        font-size: 26px;
        font-weight: 700;
        color: #E8906A;
        letter-spacing: 3px;
        margin-bottom: 6px;
    }

    .logo-sub {
        font-size: 12px;
        color: rgba(245,237,229,0.45);
    }

    .login-form-area {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .form-heading {
        font-size: 28px;
        font-weight: 800;
        color: #F5EDE5;
        margin-bottom: 6px;
    }

    .form-sub {
        font-size: 13px;
        color: rgba(245,237,229,0.45);
        margin-bottom: 24px;
    }

    .field {
        margin-bottom: 12px;
    }

    .glass-input {
        width: 100%;
        background: rgba(245,237,229,0.07);
        border: 1px solid rgba(232,144,106,0.2);
        color: #F5EDE5;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }

    .glass-input:focus { border-color: rgba(232,144,106,0.6); }
    .glass-input::placeholder { color: rgba(245,237,229,0.3); }

    .forgot-row {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 20px;
    }

    .forgot-link {
        font-size: 12px;
        color: #E8906A;
        text-decoration: none;
        font-weight: 600;
    }

    .error-msg {
        background: rgba(255,112,112,0.1);
        border: 1px solid rgba(255,112,112,0.3);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        color: #FF7070;
        margin-bottom: 14px;
    }

    .btn-primary {
        width: 100%;
        background: #E8906A;
        color: #1C100A;
        border: none;
        border-radius: 16px;
        padding: 15px;
        font-weight: 800;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-bottom: 16px;
    }

    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-primary:active:not(:disabled) { transform: scale(0.98); }

    .divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        color: rgba(245,237,229,0.25);
        font-size: 12px;
    }

    .divider::before, .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(232,144,106,0.15);
    }

    .btn-secondary {
        display: block;
        width: 100%;
        background: rgba(245,237,229,0.07);
        border: 1px solid rgba(232,144,106,0.2);
        color: #F5EDE5;
        border-radius: 16px;
        padding: 15px;
        font-weight: 700;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        text-decoration: none;
        text-align: center;
        cursor: pointer;
        transition: background 0.2s;
        margin-bottom: 32px;
    }

    .btn-secondary:hover { background: rgba(245,237,229,0.11); }

    .quick-section {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .quick-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .quick-chip {
        background: rgba(245,237,229,0.07);
        border: 1px solid rgba(232,144,106,0.2);
        color: rgba(245,237,229,0.7);
        border-radius: 20px;
        padding: 7px 14px;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: background 0.2s;
    }

    .quick-chip:hover { background: rgba(232,144,106,0.12); color: #E8906A; }
</style>
