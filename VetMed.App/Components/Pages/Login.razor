@page "/login"
@layout AuthLayout
@inject IAuthApiService AuthApi
@inject AppState AppState
@inject NavigationManager Nav

<div class="login-page">
    <div class="logo-wrap">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M26 4L6 13v14c0 11.05 8.55 21.38 20 23.93C37.45 48.38 46 38.05 46 27V13L26 4z" fill="rgba(111,207,176,0.15)" stroke="#6FCFB0" stroke-width="2"/>
            <path d="M20 24h4v-4a2 2 0 1 1 4 0v4h4a2 2 0 1 1 0 4h-4v4a2 2 0 1 1-4 0v-4h-4a2 2 0 1 1 0-4z" fill="#6FCFB0"/>
        </svg>
        <span class="logo-text">VetMed</span>
    </div>

    <h1 class="page-title">Witaj z powrotem</h1>
    <p class="page-sub">Zaloguj się do swojego konta</p>

    <div class="card">
        <div class="field">
            <label>Email</label>
            <input type="email" @bind="email" placeholder="twoj@email.pl" autocomplete="email" />
        </div>
        <div class="field">
            <label>Hasło</label>
            <input type="password" @bind="password" placeholder="••••••••" autocomplete="current-password" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error-msg">@error</div>
        }

        <button class="btn-primary" @onclick="LoginAsync" disabled="@loading">
            @if (loading)
            {
                <span>Logowanie...</span>
            }
            else
            {
                <span>Zaloguj się</span>
            }
        </button>
    </div>

    <div class="quick-login">
        <span class="quick-label">Szybki dostęp</span>
        <div class="quick-chips">
            <button class="chip" @onclick='() => QuickLogin("demo@vetmed.pl", "demo123")'>👤 Demo</button>
            <button class="chip chip-test" @onclick='() => QuickLogin("test@vetmed.pl", "")'>🧪 Test (bez hasła)</button>
            <button class="chip chip-admin" @onclick='() => QuickLogin("admin@vetmed.pl", "admin123")'>🔑 Admin</button>
        </div>
    </div>

    <div class="footer-link">
        Nie masz konta?
        <a href="/register">Zarejestruj się</a>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool loading;

    protected override void OnInitialized()
    {
        if (AppState.IsAuthenticated)
            Nav.NavigateTo("/", replace: true);
    }

    private async Task QuickLogin(string quickEmail, string quickPassword)
    {
        email = quickEmail;
        password = quickPassword;
        await LoginAsync();
    }

    private async Task LoginAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Podaj adres email.";
            return;
        }

        loading = true;
        try
        {
            var result = await AuthApi.LoginAsync(new LoginDto(email, password));
            if (result is null)
            {
                error = "Nieprawidłowy email lub hasło.";
                return;
            }
            AppState.SetAuth(result);
            Nav.NavigateTo("/", replace: true);
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            loading = false;
        }
    }
}

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 24px;
        background: #0D1F1C;
    }

    .logo-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
    }

    .logo-text {
        font-size: 28px;
        font-weight: 800;
        color: #6FCFB0;
        letter-spacing: -0.5px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #E8F5F2;
        margin-bottom: 6px;
        text-align: center;
    }

    .page-sub {
        font-size: 14px;
        color: rgba(232,245,242,0.6);
        margin-bottom: 28px;
        text-align: center;
    }

    .card {
        width: 100%;
        max-width: 380px;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(111,207,176,0.2);
        border-radius: 20px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field label {
        font-size: 13px;
        font-weight: 600;
        color: rgba(232,245,242,0.7);
    }

    .field input {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(111,207,176,0.2);
        color: #E8F5F2;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
    }

    .field input:focus {
        border-color: rgba(111,207,176,0.6);
    }

    .field input::placeholder {
        color: rgba(232,245,242,0.3);
    }

    .error-msg {
        background: rgba(255,80,80,0.12);
        border: 1px solid rgba(255,80,80,0.3);
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 13px;
        color: #ff8080;
    }

    .btn-primary {
        background: #6FCFB0;
        color: #0D1F1C;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        font-size: 15px;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 4px;
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .btn-primary:active:not(:disabled) { transform: scale(0.98); }

    .footer-link {
        margin-top: 24px;
        font-size: 14px;
        color: rgba(232,245,242,0.6);
    }

    .footer-link a {
        color: #6FCFB0;
        font-weight: 600;
        text-decoration: none;
        margin-left: 4px;
    }

    .quick-login {
        margin-top: 24px;
        width: 100%;
        max-width: 380px;
        text-align: center;
    }

    .quick-label {
        font-size: 12px;
        color: rgba(232,245,242,0.4);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        display: block;
        margin-bottom: 10px;
    }

    .quick-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .chip {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(111,207,176,0.2);
        color: #E8F5F2;
        border-radius: 20px;
        padding: 7px 14px;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .chip:hover { background: rgba(255,255,255,0.12); }

    .chip-test { border-color: rgba(255,200,80,0.3); color: #ffc850; }
    .chip-test:hover { background: rgba(255,200,80,0.1); }

    .chip-admin { border-color: rgba(180,120,255,0.3); color: #b478ff; }
    .chip-admin:hover { background: rgba(180,120,255,0.1); }
</style>
