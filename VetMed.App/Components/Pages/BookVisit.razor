@page "/book-visit"
@inject IVisitApiService VisitApi
@inject IPetApiService PetApi
@inject IDoctorApiService DoctorApi
@inject ApiClient Api
@inject AppState AppState
@inject NavigationManager Nav

<div class="book-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div>
            <div class="page-title">Umów wizytę</div>
            <div class="page-sub">Krok @CurrentPhase z 3</div>
        </div>
    </div>

    <div class="stepper">
        @foreach (var ph in phases)
        {
            var p = ph;
            var done = CurrentPhase > p.Num;
            var active = CurrentPhase == p.Num;
            <div class="ph @(active ? "ph-active" : done ? "ph-done" : "")">
                <div class="ph-badge">
                    @if (done)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    }
                    else if (p.Num == 1)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="4" r="2"/>
                            <circle cx="18" cy="8" r="2"/>
                            <circle cx="20" cy="16" r="2"/>
                            <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
                        </svg>
                    }
                    else if (p.Num == 2)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3.5 12h4l2 5 4-12 2 7h5"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    }
                </div>
                <div class="ph-krok">Krok @p.Num</div>
                <div class="ph-label">@p.Label</div>
            </div>
        }
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else
    {
        @if (step == 1)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz zwierzaka</h2>
                @if (pets.Count == 0)
                {
                    <div class="pet-empty">
                        <p class="slots-empty">Nie masz jeszcze zwierzaków.</p>
                        <button class="btn-next" @onclick='() => Nav.NavigateTo("/pets/add")'>Dodaj zwierzaka</button>
                    </div>
                }
                else
                {
                    <div class="pet-pick-list">
                        @foreach (var p in pets)
                        {
                            var pv = p;
                            <button class="pet-pick @(selectedPetId == pv.Id ? "pet-pick-active" : "")"
                                    @onclick="() => { selectedPetId = pv.Id; step = 2; }" @key="p.Id">
                                <span class="pet-emoji">@PetVisuals.Emoji(pv.Species)</span>
                                <span class="pet-pick-info">
                                    <span class="pet-pick-name">@pv.Name</span>
                                    <span class="pet-pick-sub">@pv.Species@(string.IsNullOrEmpty(pv.Breed) ? "" : " · " + pv.Breed)</span>
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>
        }
        else if (step == 2)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz typ wizyty</h2>
                <div class="cat-list">
                    @foreach (var cat in visitCategories)
                    {
                        var c = cat;
                        var open = expandedCategory == c.Name;
                        <div class="cat @(open ? "cat-open" : "")">
                            <button class="cat-head" @onclick="() => ToggleCategory(c.Name)">
                                <span class="cat-icon">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3.5 12h4l2 5 4-12 2 7h5"/>
                                    </svg>
                                </span>
                                <span class="cat-name">@c.Name</span>
                                <span class="cat-chevron">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"/>
                                    </svg>
                                </span>
                            </button>
                            @if (open)
                            {
                                <div class="cat-items">
                                    @foreach (var item in c.Items)
                                    {
                                        var it = item;
                                        <button class="cat-item @(selectedSubtype == it.Label ? "cat-item-active" : "")" @onclick="() => SelectSubtype(it)">
                                            <span class="cat-item-icon">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                                    <line x1="16" y1="2" x2="16" y2="6"/>
                                                    <line x1="8" y1="2" x2="8" y2="6"/>
                                                    <line x1="3" y1="10" x2="21" y2="10"/>
                                                </svg>
                                            </span>
                                            <span class="cat-item-label">@it.Label</span>
                                            <span class="cat-item-go">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="9 18 15 12 9 6"/>
                                                </svg>
                                            </span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
                <button class="btn-back-step" @onclick="() => step = 1">Wróć</button>
            </div>
        }
        else if (step == 3)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz lekarza</h2>
                @foreach (var d in doctors)
                {
                    var dv = d;
                    <button class="doctor-card @(selectedDoctorId == dv.Id ? "doctor-active" : "") @(!dv.IsAvailable ? "doctor-unavailable" : "")"
                            @onclick="() => SelectDoctorAsync(dv)" @key="d.Id">
                        <div class="doctor-avatar">@dv.FullName[0]</div>
                        <div class="doctor-info">
                            <div class="doctor-name">@dv.FullName</div>
                            <div class="doctor-spec">@dv.Specialization</div>
                        </div>
                        <span class="avail-badge @(dv.IsAvailable ? "avail" : "unavail")">
                            @(dv.IsAvailable ? "Dostępny" : "Niedostępny")
                        </span>
                    </button>
                }
                <button class="btn-back-step" @onclick="() => step = 2">Wróć</button>
            </div>
        }
        else if (step == 4)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz termin</h2>

                <div class="week-nav">
                    <button class="week-arrow" @onclick="PrevWeek" disabled="@(weekStart <= today)">‹</button>
                    <span class="week-label">@WeekLabel</span>
                    <button class="week-arrow" @onclick="NextWeek" disabled="@(weekStart.AddDays(7) > maxDate)">›</button>
                </div>

                @if (availabilityLoading)
                {
                    <LoadingSpinner />
                }
                else
                {
                    <div class="week-strip">
                        @foreach (var day in WeekDays)
                        {
                            var dv = day;
                            var inRange = dv >= today && dv <= maxDate;
                            var free = inRange && availability.TryGetValue(dv, out var f) && f;
                            <button class="day-cell @(daySelected && selectedDay == dv ? "day-active" : "") @(!free ? "day-disabled" : "")"
                                    disabled="@(!free)" @onclick="() => SelectDayAsync(dv)" @key="dv">
                                <span class="day-dow">@DowShort(dv.DayOfWeek)</span>
                                <span class="day-num">@dv.Day</span>
                                <span class="day-dot @(free ? "dot-free" : "dot-none")"></span>
                            </button>
                        }
                    </div>
                }

                @if (daySelected)
                {
                    <h3 class="slots-title">Godziny — @selectedDay.ToString("dd.MM")</h3>
                    @if (slotsLoading)
                    {
                        <LoadingSpinner />
                    }
                    else if (slots.Count == 0)
                    {
                        <p class="slots-empty">Brak wolnych godzin w tym dniu.</p>
                    }
                    else
                    {
                        <div class="slots-grid">
                            @foreach (var slot in slots)
                            {
                                var sv = slot;
                                <button class="slot @(selectedTime == sv.Time ? "slot-active" : "") @(!sv.Available ? "slot-taken" : "")"
                                        disabled="@(!sv.Available)"
                                        @onclick="() => selectedTime = sv.Time">@sv.Time</button>
                            }
                        </div>
                    }
                }

                <div class="step-nav">
                    <button class="btn-back-step" @onclick="() => step = 3">Wróć</button>
                    <button class="btn-next" @onclick="() => step = 5" disabled="@string.IsNullOrEmpty(selectedTime)">Dalej</button>
                </div>
            </div>
        }
        else if (step == 5)
        {
            <div class="step-section">
                <h2 class="step-title">Notatki (opcjonalnie)</h2>
                <div class="field">
                    <textarea class="glass-input glass-textarea" @bind="notes" placeholder="Opisz objawy lub powód wizyty..." rows="4"></textarea>
                </div>

                <div class="summary-card">
                    <div class="summary-row">
                        <span class="s-label">Rodzaj</span>
                        <span class="s-value">@(selectedSubtype ?? VisitLabel(selectedType))</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Lekarz</span>
                        <span class="s-value">@(doctors.FirstOrDefault(d => d.Id == selectedDoctorId)?.FullName ?? "-")</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Data</span>
                        <span class="s-value">@selectedDay.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Godzina</span>
                        <span class="s-value">@selectedTime</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Zwierzak</span>
                        <span class="s-value">@(pets.FirstOrDefault(p => p.Id == selectedPetId)?.Name ?? "-")</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="error-msg">@error</div>
                }

                <div class="step-nav">
                    <button class="btn-back-step" @onclick="() => step = 4">Wróć</button>
                    <button class="btn-confirm" @onclick="ConfirmAsync" disabled="@(submitting || !CanSubmit)">
                        @(submitting ? "Rezerwowanie..." : "Potwierdź wizytę")
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "petId")] public int? PetIdQuery { get; set; }

    private int step = 1;
    private VetMed.Shared.Enums.VisitType selectedType = VetMed.Shared.Enums.VisitType.Kontrola;
    private int? selectedDoctorId;
    private DateOnly selectedDay;
    private bool daySelected;
    private string selectedTime = "";
    private string? notes;
    private int selectedPetId;
    private string? error;
    private bool loading = true;
    private bool submitting;

    private List<DoctorDto> doctors = new();
    private List<PetDto> pets = new();
    private List<SlotDto> slots = new();
    private bool slotsLoading;

    private readonly DateOnly today = DateOnly.FromDateTime(DateTime.Today);
    private readonly DateOnly maxDate = DateOnly.FromDateTime(DateTime.Today).AddDays(13);
    private DateOnly weekStart = DateOnly.FromDateTime(DateTime.Today);
    private Dictionary<DateOnly, bool> availability = new();
    private bool availabilityLoading;

    private static readonly string[] dowShort = { "Nd", "Pn", "Wt", "Śr", "Cz", "Pt", "So" };
    private static readonly string[] monShort = { "", "sty", "lut", "mar", "kwi", "maj", "cze", "lip", "sie", "wrz", "paź", "lis", "gru" };

    private IEnumerable<DateOnly> WeekDays => Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i));

    private string WeekLabel
    {
        get
        {
            var last = weekStart.AddDays(6);
            if (last > maxDate) last = maxDate;
            return $"{weekStart.Day} {monShort[weekStart.Month]} – {last.Day} {monShort[last.Month]}";
        }
    }

    private static string DowShort(DayOfWeek d) => dowShort[(int)d];

    private record VisitSubtype(string Label, VetMed.Shared.Enums.VisitType Type);
    private record VisitCategory(string Name, VisitSubtype[] Items);

    private static readonly VisitCategory[] visitCategories = new[]
    {
        new VisitCategory("Interna i profilaktyka", new[]
        {
            new VisitSubtype("Wizyta profilaktyczna", VetMed.Shared.Enums.VisitType.Kontrola),
            new VisitSubtype("Wizyta internistyczna", VetMed.Shared.Enums.VisitType.Kontrola),
            new VisitSubtype("Szczepienie", VetMed.Shared.Enums.VisitType.Szczepienie),
            new VisitSubtype("Pobranie krwi", VetMed.Shared.Enums.VisitType.Diagnostyka),
        }),
        new VisitCategory("Diagnostyka obrazowa", new[]
        {
            new VisitSubtype("RTG", VetMed.Shared.Enums.VisitType.Diagnostyka),
            new VisitSubtype("USG", VetMed.Shared.Enums.VisitType.Diagnostyka),
        }),
        new VisitCategory("Ortopedia", new[]
        {
            new VisitSubtype("Konsultacja ortopedyczna", VetMed.Shared.Enums.VisitType.Kontrola),
            new VisitSubtype("Badanie kulawizny", VetMed.Shared.Enums.VisitType.Kontrola),
        }),
        new VisitCategory("Dermatologia i alergologia", new[]
        {
            new VisitSubtype("Konsultacja dermatologiczna", VetMed.Shared.Enums.VisitType.Kontrola),
            new VisitSubtype("Testy alergiczne", VetMed.Shared.Enums.VisitType.Diagnostyka),
        }),
        new VisitCategory("Okulistyka", new[]
        {
            new VisitSubtype("Konsultacja okulistyczna", VetMed.Shared.Enums.VisitType.Kontrola),
        }),
        new VisitCategory("Chirurgia i zabiegi", new[]
        {
            new VisitSubtype("Zabieg chirurgiczny", VetMed.Shared.Enums.VisitType.Zabieg),
            new VisitSubtype("Sterylizacja / kastracja", VetMed.Shared.Enums.VisitType.Zabieg),
            new VisitSubtype("Zdjęcie szwów", VetMed.Shared.Enums.VisitType.Kontrola),
        }),
        new VisitCategory("Nagły przypadek", new[]
        {
            new VisitSubtype("Wizyta nagła", VetMed.Shared.Enums.VisitType.Nagly),
        }),
    };

    private string? expandedCategory = visitCategories[0].Name;
    private string? selectedSubtype;

    private void ToggleCategory(string name) => expandedCategory = expandedCategory == name ? null : name;

    private void SelectSubtype(VisitSubtype s)
    {
        selectedType = s.Type;
        selectedSubtype = s.Label;
        step = 3;
    }

    private record Phase(int Num, string Label);

    private static readonly Phase[] phases =
    {
        new(1, "Zwierzę"),
        new(2, "Typ wizyty"),
        new(3, "Termin"),
    };

    private int CurrentPhase => step <= 1 ? 1 : step == 2 ? 2 : 3;

    private bool CanSubmit => selectedDoctorId.HasValue && selectedPetId > 0 && !string.IsNullOrEmpty(selectedTime);

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var dTask = DoctorApi.GetDoctorsAsync();
            var pTask = PetApi.GetPetsAsync();
            await Task.WhenAll(dTask, pTask);
            doctors = dTask.Result;
            pets = pTask.Result;

            if (PetIdQuery.HasValue && pets.Any(p => p.Id == PetIdQuery.Value))
            {
                selectedPetId = PetIdQuery.Value;
                step = 2;
            }
        }
        catch { }
        finally { loading = false; }
    }

    private async Task SelectDoctorAsync(DoctorDto doctor)
    {
        if (!doctor.IsAvailable) return;
        selectedDoctorId = doctor.Id;
        step = 4;
        weekStart = today;
        daySelected = false;
        selectedTime = "";
        slots = new();
        await LoadAvailabilityAsync();
    }

    private async Task LoadAvailabilityAsync()
    {
        availabilityLoading = true;
        try
        {
            var days = await VisitApi.GetAvailabilityAsync(selectedDoctorId!.Value, today, 14);
            availability = days.ToDictionary(d => d.Date, d => d.HasFreeSlots);
        }
        catch
        {
            availability = new();
        }
        finally
        {
            availabilityLoading = false;
        }
    }

    private void PrevWeek()
    {
        var prev = weekStart.AddDays(-7);
        weekStart = prev < today ? today : prev;
    }

    private void NextWeek()
    {
        if (weekStart.AddDays(7) <= maxDate)
            weekStart = weekStart.AddDays(7);
    }

    private async Task SelectDayAsync(DateOnly day)
    {
        selectedDay = day;
        daySelected = true;
        selectedTime = "";
        slotsLoading = true;
        try
        {
            slots = await VisitApi.GetSlotsAsync(selectedDoctorId!.Value, day);
        }
        catch
        {
            slots = new();
        }
        finally
        {
            slotsLoading = false;
        }
    }

    private async Task ConfirmAsync()
    {
        error = null;
        if (!CanSubmit)
        {
            error = "Wypełnij wszystkie wymagane pola.";
            return;
        }

        submitting = true;
        try
        {
            var timeParts = selectedTime.Split(':');
            var wallClock = selectedDay.ToDateTime(TimeOnly.MinValue).AddHours(int.Parse(timeParts[0])).AddMinutes(int.Parse(timeParts[1]));
            // Wysyłamy wybraną godzinę zegarową bez konwersji stref — serwer porównuje ją
            // wprost z grafikiem lekarza (godziny grafiku są "naiwne"/UTC), tak jak prezentowane sloty.
            var scheduledAt = DateTime.SpecifyKind(wallClock, DateTimeKind.Utc);

            var finalNotes = string.IsNullOrWhiteSpace(selectedSubtype)
                ? notes
                : string.IsNullOrWhiteSpace(notes) ? selectedSubtype : $"{selectedSubtype} — {notes}";

            var dto = new CreateVisitDto(scheduledAt, selectedType, selectedPetId, selectedDoctorId!.Value, finalNotes);
            var result = await VisitApi.CreateVisitAsync(dto);
            if (result is null)
            {
                error = Api.LastError ?? "Nie udało się zarezerwować wizyty. Spróbuj ponownie.";
                return;
            }
            Nav.NavigateTo("/history", replace: true);
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            submitting = false;
        }
    }

    private static string VisitLabel(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "Szczepienie",
        VetMed.Shared.Enums.VisitType.Kontrola    => "Kontrola",
        VetMed.Shared.Enums.VisitType.Zabieg      => "Zabieg",
        VetMed.Shared.Enums.VisitType.Nagly       => "Nagły",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "Diagnostyka",
        _                                          => t.ToString()
    };
}

<style>
    .book-page {
        padding: 20px 16px 32px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
        padding-top: 8px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s;
    }

    .back-btn:hover { background: var(--mintGlow); }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: var(--text);
    }

    .page-sub {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    .stepper {
        display: flex;
        gap: 6px;
        margin-bottom: 28px;
    }

    .ph {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        text-align: center;
    }

    .ph-badge {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--inputBg);
        color: var(--muted);
        border: 1.5px solid transparent;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
    }

    .ph-active .ph-badge {
        background: var(--mintGlow);
        color: var(--mint);
        border-color: var(--mint);
    }

    .ph-done .ph-badge {
        background: var(--mint);
        color: var(--onMint);
    }

    .ph-krok {
        font-size: 11px;
        font-weight: 700;
        color: var(--muted);
    }

    .ph-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
    }

    .ph-active .ph-krok, .ph-active .ph-label { color: var(--mint); }
    .ph-done .ph-krok, .ph-done .ph-label { color: var(--textSub); }

    .step-section {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .step-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
    }

    .cat-list { display: flex; flex-direction: column; gap: 10px; }

    .cat {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--cardShadow);
        transition: border-color 0.2s;
    }

    .cat-open { border-color: var(--mint); }

    .cat-head {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        padding: 16px;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .cat-icon { color: var(--mint); display: flex; flex-shrink: 0; }

    .cat-name {
        flex: 1;
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
    }

    .cat-chevron {
        color: var(--muted);
        display: flex;
        flex-shrink: 0;
        transition: transform 0.2s;
    }

    .cat-open .cat-chevron { transform: rotate(180deg); color: var(--mint); }

    .cat-items {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--faint);
    }

    .cat-item {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--faint);
        padding: 14px 16px;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
