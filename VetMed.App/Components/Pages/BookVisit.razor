@page "/book-visit"
@inject IVisitApiService VisitApi
@inject IPetApiService PetApi
@inject IDoctorApiService DoctorApi
@inject ApiClient Api
@inject AppState AppState
@inject NavigationManager Nav

<div class="book-page">
    <div class="page-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <div>
            <div class="page-title">Umów wizytę</div>
            <div class="page-sub">Krok @step z 5</div>
        </div>
    </div>

    <div class="steps-indicator">
        @for (int i = 1; i <= 5; i++)
        {
            var si = i;
            <div class="step-dot @(step == si ? "step-active" : step > si ? "step-done" : "")"></div>
        }
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else
    {
        @if (step == 1)
        {
            <div class="step-section">
                <h2 class="step-title">Rodzaj wizyty</h2>
                <div class="type-grid">
                    @foreach (var t in visitTypes)
                    {
                        var tv = t;
                        <button class="type-card @(selectedType == tv.Type ? "type-card-active" : "")" @onclick="() => { selectedType = tv.Type; step = 2; }">
                            <span class="type-icon">@tv.Icon</span>
                            <span class="type-label">@tv.Label</span>
                        </button>
                    }
                </div>
            </div>
        }
        else if (step == 2)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz lekarza</h2>
                @foreach (var d in doctors)
                {
                    var dv = d;
                    <button class="doctor-card @(selectedDoctorId == dv.Id ? "doctor-active" : "") @(!dv.IsAvailable ? "doctor-unavailable" : "")"
                            @onclick="() => { if (dv.IsAvailable) { selectedDoctorId = dv.Id; step = 3; } }" @key="d.Id">
                        <div class="doctor-avatar">@dv.FullName[0]</div>
                        <div class="doctor-info">
                            <div class="doctor-name">@dv.FullName</div>
                            <div class="doctor-spec">@dv.Specialization</div>
                        </div>
                        <span class="avail-badge @(dv.IsAvailable ? "avail" : "unavail")">
                            @(dv.IsAvailable ? "Dostępny" : "Niedostępny")
                        </span>
                    </button>
                }
                <button class="btn-back-step" @onclick="() => step = 1">Wróć</button>
            </div>
        }
        else if (step == 3)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz datę</h2>
                <div class="field">
                    <input type="date" class="glass-input" @bind="selectedDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="step-nav">
                    <button class="btn-back-step" @onclick="() => step = 2">Wróć</button>
                    <button class="btn-next" @onclick="GoToSlotsAsync" disabled="@(selectedDate < DateTime.Today)">Dalej</button>
                </div>
            </div>
        }
        else if (step == 4)
        {
            <div class="step-section">
                <h2 class="step-title">Wybierz godzinę</h2>
                @if (slotsLoading)
                {
                    <LoadingSpinner />
                }
                else if (slots.Count == 0)
                {
                    <p class="slots-empty">Lekarz nie przyjmuje w wybranym dniu. Wybierz inną datę.</p>
                }
                else
                {
                    <div class="slots-grid">
                        @foreach (var slot in slots)
                        {
                            var sv = slot;
                            <button class="slot @(selectedTime == sv.Time ? "slot-active" : "") @(!sv.Available ? "slot-taken" : "")"
                                    disabled="@(!sv.Available)"
                                    @onclick="() => selectedTime = sv.Time">@sv.Time</button>
                        }
                    </div>
                }
                <div class="step-nav">
                    <button class="btn-back-step" @onclick="() => step = 3">Wróć</button>
                    <button class="btn-next" @onclick="() => step = 5" disabled="@string.IsNullOrEmpty(selectedTime)">Dalej</button>
                </div>
            </div>
        }
        else if (step == 5)
        {
            <div class="step-section">
                <h2 class="step-title">Notatki (opcjonalnie)</h2>
                <div class="field">
                    <textarea class="glass-input glass-textarea" @bind="notes" placeholder="Opisz objawy lub powód wizyty..." rows="4"></textarea>
                </div>

                <div class="summary-card">
                    <div class="summary-row">
                        <span class="s-label">Rodzaj</span>
                        <span class="s-value">@VisitLabel(selectedType)</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Lekarz</span>
                        <span class="s-value">@(doctors.FirstOrDefault(d => d.Id == selectedDoctorId)?.FullName ?? "-")</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Data</span>
                        <span class="s-value">@selectedDate.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="summary-row">
                        <span class="s-label">Godzina</span>
                        <span class="s-value">@selectedTime</span>
                    </div>
                    @if (pets.Count > 0)
                    {
                        <div class="summary-row">
                            <span class="s-label">Zwierzak</span>
                            <select class="s-select" @bind="selectedPetId">
                                @foreach (var p in pets)
                                {
                                    <option value="@p.Id" @key="p.Id">@p.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="error-msg">@error</div>
                }

                <div class="step-nav">
                    <button class="btn-back-step" @onclick="() => step = 4">Wróć</button>
                    <button class="btn-confirm" @onclick="ConfirmAsync" disabled="@(submitting || !CanSubmit)">
                        @(submitting ? "Rezerwowanie..." : "Potwierdź wizytę")
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "petId")] public int? PetIdQuery { get; set; }

    private int step = 1;
    private VetMed.Shared.Enums.VisitType selectedType = VetMed.Shared.Enums.VisitType.Kontrola;
    private int? selectedDoctorId;
    private DateTime selectedDate = DateTime.Today;
    private string selectedTime = "";
    private string? notes;
    private int selectedPetId;
    private string? error;
    private bool loading = true;
    private bool submitting;

    private List<DoctorDto> doctors = new();
    private List<PetDto> pets = new();
    private List<SlotDto> slots = new();
    private bool slotsLoading;

    private record VisitTypeOption(VetMed.Shared.Enums.VisitType Type, string Icon, string Label);

    private static readonly VisitTypeOption[] visitTypes = new[]
    {
        new VisitTypeOption(VetMed.Shared.Enums.VisitType.Szczepienie, "💉", "Szczepienie"),
        new VisitTypeOption(VetMed.Shared.Enums.VisitType.Kontrola,    "🩺", "Kontrola"),
        new VisitTypeOption(VetMed.Shared.Enums.VisitType.Zabieg,      "🔬", "Zabieg"),
        new VisitTypeOption(VetMed.Shared.Enums.VisitType.Nagly,       "🚨", "Nagły"),
    };

    private bool CanSubmit => selectedDoctorId.HasValue && selectedPetId > 0 && !string.IsNullOrEmpty(selectedTime);

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var dTask = DoctorApi.GetDoctorsAsync();
            var pTask = PetApi.GetPetsAsync();
            await Task.WhenAll(dTask, pTask);
            doctors = dTask.Result;
            pets = pTask.Result;

            if (PetIdQuery.HasValue && pets.Any(p => p.Id == PetIdQuery.Value))
                selectedPetId = PetIdQuery.Value;
            else if (pets.Count > 0)
                selectedPetId = pets[0].Id;
        }
        catch { }
        finally { loading = false; }
    }

    private async Task GoToSlotsAsync()
    {
        selectedTime = "";
        step = 4;
        slotsLoading = true;
        try
        {
            slots = await VisitApi.GetSlotsAsync(selectedDoctorId!.Value, DateOnly.FromDateTime(selectedDate));
        }
        catch
        {
            slots = new();
        }
        finally
        {
            slotsLoading = false;
        }
    }

    private async Task ConfirmAsync()
    {
        error = null;
        if (!CanSubmit)
        {
            error = "Wypełnij wszystkie wymagane pola.";
            return;
        }

        submitting = true;
        try
        {
            var timeParts = selectedTime.Split(':');
            var wallClock = selectedDate.Date.AddHours(int.Parse(timeParts[0])).AddMinutes(int.Parse(timeParts[1]));
            var scheduledAt = DateTime.SpecifyKind(wallClock, DateTimeKind.Utc);

            var dto = new CreateVisitDto(scheduledAt, selectedType, selectedPetId, selectedDoctorId!.Value, notes);
            var result = await VisitApi.CreateVisitAsync(dto);
            if (result is null)
            {
                error = Api.LastError ?? "Nie udało się zarezerwować wizyty. Spróbuj ponownie.";
                return;
            }
            Nav.NavigateTo("/history", replace: true);
        }
        catch
        {
            error = "Błąd połączenia. Spróbuj ponownie.";
        }
        finally
        {
            submitting = false;
        }
    }

    private static string VisitLabel(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "Szczepienie",
        VetMed.Shared.Enums.VisitType.Kontrola    => "Kontrola",
        VetMed.Shared.Enums.VisitType.Zabieg      => "Zabieg",
        VetMed.Shared.Enums.VisitType.Nagly       => "Nagły",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "Diagnostyka",
        _                                          => t.ToString()
    };
}

<style>
    .book-page {
        padding: 20px 16px 32px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
        padding-top: 8px;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        background: rgba(26,44,34,0.07);
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 12px;
        color: #1A2C22;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s;
    }

    .back-btn:hover { background: rgba(60,184,122,0.1); }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: #1A2C22;
    }

    .page-sub {
        font-size: 12px;
        color: rgba(26,44,34,0.45);
        margin-top: 2px;
    }

    .steps-indicator {
        display: flex;
        gap: 6px;
        justify-content: center;
        margin-bottom: 28px;
    }

    .step-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(26,44,34,0.12);
        transition: background 0.3s, transform 0.2s, width 0.3s;
    }

    .step-active {
        background: #3CB87A;
        transform: scale(1.3);
        width: 20px;
        border-radius: 4px;
    }

    .step-done {
        background: rgba(60,184,122,0.45);
    }

    .step-section {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .step-title {
        font-size: 18px;
        font-weight: 700;
        color: #1A2C22;
        margin-bottom: 4px;
    }

    .type-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .type-card {
        background: #FFFFFF;
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 20px;
        padding: 22px 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        box-shadow: 0 4px 12px rgba(26,44,34,0.05);
    }

    .type-card-active {
        border-color: #3CB87A;
        background: rgba(60,184,122,0.15);
    }

    .type-card:active { transform: scale(0.97); }

    .type-icon { font-size: 30px; }

    .type-label {
        font-size: 13px;
        font-weight: 700;
        color: #1A2C22;
    }

    .doctor-card {
        background: #FFFFFF;
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 16px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        width: 100%;
        text-align: left;
        transition: border-color 0.2s, background 0.2s;
        box-shadow: 0 4px 12px rgba(26,44,34,0.05);
    }

    .doctor-active {
        border-color: #3CB87A;
        background: rgba(60,184,122,0.12);
    }

    .doctor-unavailable { opacity: 0.45; cursor: not-allowed; }

    .doctor-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: rgba(60,184,122,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 700;
        color: #3CB87A;
        flex-shrink: 0;
    }

    .doctor-info { flex: 1; }

    .doctor-name {
        font-size: 14px;
        font-weight: 700;
        color: #1A2C22;
    }

    .doctor-spec {
        font-size: 12px;
        color: rgba(26,44,34,0.45);
        margin-top: 2px;
    }

    .avail-badge {
        font-size: 11px;
        font-weight: 600;
        border-radius: 8px;
        padding: 4px 9px;
        white-space: nowrap;
    }

    .avail  { background: rgba(60,184,122,0.15); color: #3CB87A; }
    .unavail { background: rgba(255,112,112,0.1); color: #FF7070; }

    .field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .glass-input {
        width: 100%;
        background: rgba(26,44,34,0.07);
        border: 1px solid rgba(60,184,122,0.2);
        color: #1A2C22;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }

    .glass-input:focus { border-color: rgba(60,184,122,0.6); }
    .glass-input::placeholder { color: rgba(26,44,34,0.25); }

    .glass-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .slots-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .slot {
        background: rgba(26,44,34,0.06);
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 12px;
        padding: 9px 16px;
        color: rgba(26,44,34,0.7);
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
    }

    .slot-active {
        background: rgba(60,184,122,0.2);
        border-color: #3CB87A;
        color: #3CB87A;
    }

    .slot-taken {
        opacity: 0.4;
        text-decoration: line-through;
        cursor: not-allowed;
    }

    .slots-empty {
        font-size: 13px;
        color: rgba(26,44,34,0.5);
        padding: 8px 2px;
    }

    .summary-card {
        background: #FFFFFF;
        border: 1px solid rgba(60,184,122,0.2);
        border-radius: 20px;
        padding: 4px 0;
        box-shadow: 0 8px 24px rgba(26,44,34,0.08);
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 13px 18px;
        border-bottom: 1px solid rgba(26,44,34,0.05);
    }

    .summary-row:last-child { border-bottom: none; }

    .s-label {
        font-size: 13px;
        color: rgba(26,44,34,0.45);
    }

    .s-value {
        font-size: 14px;
        font-weight: 600;
        color: #1A2C22;
    }

    .s-select {
        background: rgba(26,44,34,0.07);
        border: 1px solid rgba(60,184,122,0.2);
        color: #1A2C22;
        border-radius: 8px;
        padding: 5px 10px;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        outline: none;
    }

    .s-select option { background: #EDF7F1; }

    .step-nav {
        display: flex;
        gap: 10px;
        margin-top: 4px;
    }

    .btn-back-step {
        background: rgba(26,44,34,0.07);
        border: 1px solid rgba(60,184,122,0.2);
        color: rgba(26,44,34,0.6);
        border-radius: 14px;
        padding: 13px 20px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s;
    }

    .btn-back-step:hover { background: rgba(26,44,34,0.12); }

    .btn-next, .btn-confirm {
        background: #3CB87A;
        color: #F8FCF9;
        border: none;
        border-radius: 14px;
        padding: 13px;
        font-weight: 800;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        flex: 1;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }

    .btn-next:disabled, .btn-confirm:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-next:active:not(:disabled), .btn-confirm:active:not(:disabled) { transform: scale(0.98); }

    .error-msg {
        background: rgba(255,112,112,0.1);
        border: 1px solid rgba(255,112,112,0.3);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        color: #FF7070;
    }
</style>
