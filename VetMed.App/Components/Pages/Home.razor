        padding: 20px 16px 8px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 8px;
    }

    .greeting {
        font-size: 22px;
        font-weight: 800;
        color: #E8F5F2;
    }

    .sub {
        font-size: 13px;
        color: rgba(232,245,242,0.6);
        margin-top: 2px;
    }

    .avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(111,207,176,0.2);
        border: 1px solid rgba(111,207,176,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 700;
        color: #6FCFB0;
        flex-shrink: 0;
    }

    .section {}

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #E8F5F2;
    }

    .see-all {
        font-size: 13px;
        color: #6FCFB0;
        text-decoration: none;
        font-weight: 600;
    }

    .btn-new {
        background: rgba(111,207,176,0.15);
        border: 1px solid rgba(111,207,176,0.3);
        color: #6FCFB0;
        border-radius: 10px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    .pets-scroll {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
    }

    .pets-scroll::-webkit-scrollbar { display: none; }

    .add-card {
        background: rgba(255,255,255,0.04);
        border: 1px dashed rgba(111,207,176,0.3);
        border-radius: 16px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
