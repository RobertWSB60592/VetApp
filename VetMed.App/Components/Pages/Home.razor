        color: rgba(111,207,176,0.6);
    }

    .add-label {
        font-size: 12px;
        color: rgba(232,245,242,0.5);
    }

    .visit-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(111,207,176,0.15);
        border-radius: 14px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
    }

    .visit-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .visit-info { flex: 1; }

    .visit-title {
        font-size: 14px;
        font-weight: 600;
        color: #E8F5F2;
    }

    .visit-meta {
        font-size: 12px;
        color: rgba(232,245,242,0.55);
        margin-top: 2px;
    }

    .visit-badge {
        font-size: 11px;
        font-weight: 600;
        color: #6FCFB0;
        background: rgba(111,207,176,0.12);
        border-radius: 8px;
        padding: 3px 8px;
        white-space: nowrap;
    }

    .empty-card {
        background: rgba(255,255,255,0.04);
        border: 1px dashed rgba(111,207,176,0.2);
        border-radius: 16px;
        padding: 28px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        color: rgba(232,245,242,0.5);
        font-size: 14px;
    }

    .empty-icon { font-size: 32px; }

    .btn-primary-sm {
        background: #6FCFB0;
        color: #0D1F1C;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        margin-top: 4px;
    }

    .muted-text {
        font-size: 13px;
        color: rgba(232,245,242,0.45);
        text-align: center;
        padding: 16px 0;
