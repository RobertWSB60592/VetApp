@page "/"
@inject AppState AppState
@inject IPetApiService PetApi
@inject IVisitApiService VisitApi
@inject NavigationManager Nav

<div class="home-page">
    <div class="home-header">
        <div>
            <h1 class="greeting">Cześć, @FirstName!</h1>
            <p class="greeting-sub">Co słychać u twoich pupili?</p>
        </div>
        <div class="header-actions">
            <button class="icon-btn" @onclick='() => Nav.NavigateTo("/search")' aria-label="Szukaj">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </button>
            <button class="avatar" @onclick='() => Nav.NavigateTo("/profile")'>@FirstName.Substring(0, 1)</button>
        </div>
    </div>

    <button class="clinic-card" @onclick='() => Nav.NavigateTo("/clinic")'>
        <div class="clinic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/><line x1="12" y1="8" x2="12" y2="11"/><line x1="10.5" y1="9.5" x2="13.5" y2="9.5"/>
            </svg>
        </div>
        <div class="clinic-text">
            <span class="clinic-label">Twoja przychodnia</span>
            <span class="clinic-name">@ClinicInfo.FullName</span>
            <span class="clinic-meta">@ClinicInfo.Address · dziś @ClinicInfo.HoursWeekday</span>
        </div>
        <span class="clinic-chev">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
    </button>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else if (loadError)
    {
        <div class="load-error">
            <span class="load-error-icon">&#x26A0;&#xFE0F;</span>
            <span class="load-error-text">Nie udało się wczytać danych</span>
            <span class="load-error-sub">Sprawdź połączenie i spróbuj ponownie.</span>
            <button class="retry-btn" @onclick="LoadAsync">Ponów</button>
        </div>
    }
    else
    {
        <section class="section">
            <div class="section-header">
                <span class="section-title">Twoje zwierzaki</span>
                <a href="/pets" class="see-all">Zobacz wszystkie</a>
            </div>
            <div class="pets-scroll">
                @foreach (var pet in pets)
                {
                    var petId = pet.Id;
                    <PetCard Pet="pet" OnClick="() => Nav.NavigateTo(PetRoute(petId))" @key="pet.Id" />
                }
                <div class="add-pet-card" @onclick='() => Nav.NavigateTo("/pets/add")'>
                    <span class="add-pet-plus">+</span>
                    <span class="add-pet-label">Dodaj</span>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="section-header">
                <span class="section-title">Nadchodzące wizyty</span>
                <button class="btn-new-visit" @onclick='() => Nav.NavigateTo("/book-visit")'>+ Nowa wizyta</button>
            </div>

            @if (upcomingVisits.Count == 0)
            {
                <div class="empty-card">
                    <span class="empty-icon">&#x1F4C5;</span>
                    <span class="empty-text">Brak zaplanowanych wizyt</span>
                    <button class="btn-primary-sm" @onclick='() => Nav.NavigateTo("/book-visit")'>Umów wizytę</button>
                </div>
            }
            else
            {
                @foreach (var v in upcomingVisits)
                {
                    var vid = v.Id;
                    <div class="visit-card visit-card-clickable" @key="v.Id" @onclick='() => Nav.NavigateTo($"/visits/{vid}")'>
                        <div class="visit-dot" style="background:@VisitColor(v.Type)"></div>
                        <div class="visit-info">
                            <div class="visit-title">@v.PetName — @VisitLabel(v.Type)</div>
                            <div class="visit-meta">@v.ScheduledAt.ToString("dd MMM, HH:mm") · @v.DoctorName</div>
                        </div>
                        <span class="visit-badge">@StatusLabel(v.Status)</span>
                        <span class="visit-chevron">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </span>
                    </div>
                }
            }
        </section>

        <section class="section">
            <div class="section-header">
                <span class="section-title">Ostatnie wizyty</span>
                <a href="/history" class="see-all">Historia</a>
            </div>
            @if (recentVisits.Count == 0)
            {
                <p class="muted-text">Brak historii wizyt.</p>
            }
            else
            {
                @foreach (var v in recentVisits)
                {
                    <div class="visit-card" @key="v.Id">
                        <div class="visit-dot" style="background:@VisitColor(v.Type)"></div>
                        <div class="visit-info">
                            <div class="visit-title">@v.PetName — @VisitLabel(v.Type)</div>
                            <div class="visit-meta">@v.ScheduledAt.ToString("dd MMM yyyy") · @v.DoctorName</div>
                        </div>
                    </div>
                }
            }
        </section>
    }
</div>

@code {
    private List<PetDto> pets = new();
    private List<VisitDto> upcomingVisits = new();
    private List<VisitDto> recentVisits = new();
    private bool loading = true;
    private bool loadError;

    private string FirstName => AppState.CurrentOwner?.FullName?.Split(' ')[0] ?? "Użytkowniku";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        loadError = false;
        try
        {
            var petTask = PetApi.GetPetsAsync();
            var visitTask = VisitApi.GetVisitsAsync();
            await Task.WhenAll(petTask, visitTask);

            pets = petTask.Result;
            var allVisits = visitTask.Result;
            var now = DateTime.Now;

            upcomingVisits = allVisits
                .Where(v => v.ScheduledAt > now
                    && v.Status != VetMed.Shared.Enums.VisitStatus.Odwolana
                    && v.Status != VetMed.Shared.Enums.VisitStatus.Zakonczona)
                .OrderBy(v => v.ScheduledAt)
                .ToList();

            recentVisits = allVisits
                .Where(v => v.ScheduledAt <= now
                    && v.Status != VetMed.Shared.Enums.VisitStatus.Odwolana)
                .OrderByDescending(v => v.ScheduledAt)
                .Take(3)
                .ToList();
        }
        catch
        {
            loadError = true;
        }
        finally
        {
            loading = false;
        }
    }

    private static string PetRoute(int id) => $"/pets/{id}";

    private static string VisitColor(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "var(--vSzczep)",
        VetMed.Shared.Enums.VisitType.Zabieg      => "var(--vZabieg)",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "var(--vDiag)",
        VetMed.Shared.Enums.VisitType.Nagly       => "var(--danger)",
        _                                          => "var(--vWizyta)"
    };

    private static string VisitLabel(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "Szczepienie",
        VetMed.Shared.Enums.VisitType.Kontrola    => "Kontrola",
        VetMed.Shared.Enums.VisitType.Zabieg      => "Zabieg",
        VetMed.Shared.Enums.VisitType.Nagly       => "Nagły",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "Diagnostyka",
        _                                          => t.ToString()
    };

    private static string StatusLabel(VetMed.Shared.Enums.VisitStatus s) => s switch
    {
        VetMed.Shared.Enums.VisitStatus.Zaplanowana  => "Zaplanowana",
        VetMed.Shared.Enums.VisitStatus.Potwierdzona => "Potwierdzona",
        VetMed.Shared.Enums.VisitStatus.Zakonczona   => "Zakończona",
        VetMed.Shared.Enums.VisitStatus.Odwolana     => "Odwołana",
        VetMed.Shared.Enums.VisitStatus.Oczekujaca   => "Oczekująca",
        _                                             => s.ToString()
    };
}

<style>
    .home-page {
        padding: 20px 16px 8px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .home-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 8px;
    }

    .greeting {
        font-size: 24px;
        font-weight: 800;
        color: var(--text);
    }

    .greeting-sub {
        font-size: 13px;
        color: var(--muted);
        margin-top: 3px;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .icon-btn {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
    }

    .icon-btn:active { background: var(--mintGlow); }

    .avatar {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: var(--mintGlow);
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 700;
        color: var(--mint);
        flex-shrink: 0;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .clinic-card {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        text-align: left;
        background: linear-gradient(135deg, var(--mintGlow), transparent);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--cardShadow);
        padding: 14px 16px;
        cursor: pointer;
        font-family: 'Plus Jakarta Sans', sans-serif;
        transition: transform 0.12s, border-color 0.2s;
    }

    .clinic-card:active { transform: scale(0.99); border-color: var(--mint); }

    .clinic-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: var(--mintGlow);
        border: 1px solid var(--border);
        color: var(--mint);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .clinic-text { flex: 1; display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .clinic-label { font-size: 10px; font-weight: 700; letter-spacing: 0.3px; text-transform: uppercase; color: var(--mint); }
    .clinic-name { font-size: 15px; font-weight: 700; color: var(--text); }
    .clinic-meta { font-size: 11px; color: var(--muted); }
    .clinic-chev { color: var(--muted); display: flex; flex-shrink: 0; }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
    }

    .see-all {
        font-size: 13px;
        color: var(--mint);
        text-decoration: none;
        font-weight: 600;
    }

    .btn-new-visit {
        background: var(--mintGlow);
        border: 1px solid var(--border);
        color: var(--mint);
        border-radius: 10px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
    }

    .pets-scroll {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
    }

    .pets-scroll::-webkit-scrollbar { display: none; }

    .add-pet-card {
        background: var(--faint);
        border: 1px dashed var(--border);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        cursor: pointer;
        min-width: 100px;
        min-height: 158px;
        flex-shrink: 0;
        transition: border-color 0.2s;
    }

    .add-pet-card:active { transform: scale(0.97); }

    .add-pet-plus {
        font-size: 28px;
        color: var(--mint);
    }

    .add-pet-label {
        font-size: 12px;
        color: var(--muted);
    }

    .visit-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
        box-shadow: var(--cardShadow);
    }

    .visit-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 8px currentColor;
    }

    .visit-card-clickable { cursor: pointer; transition: border-color 0.2s, transform 0.12s; }
    .visit-card-clickable:active { transform: scale(0.99); border-color: var(--mint); }

    .visit-chevron { color: var(--muted); display: flex; flex-shrink: 0; }

    .visit-info { flex: 1; }

    .visit-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .visit-meta {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    .visit-badge {
        font-size: 11px;
        font-weight: 600;
        color: var(--mint);
        background: var(--mintGlow);
        border-radius: 8px;
        padding: 3px 8px;
        white-space: nowrap;
    }

    .empty-card {
        background: var(--faint);
        border: 1px dashed var(--border);
        border-radius: 16px;
        padding: 28px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        color: var(--muted);
        font-size: 14px;
        text-align: center;
    }

    .empty-icon { font-size: 32px; }
    .empty-text { font-size: 14px; }

    .btn-primary-sm {
        background: var(--mint);
        color: var(--onMint);
        border: none;
        border-radius: 12px;
        padding: 10px 22px;
        font-weight: 700;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        margin-top: 4px;
        transition: opacity 0.2s;
    }

    .btn-primary-sm:active { opacity: 0.85; }

    .muted-text {
        font-size: 13px;
        color: var(--muted);
        text-align: center;
        padding: 16px 0;
    }
</style>
