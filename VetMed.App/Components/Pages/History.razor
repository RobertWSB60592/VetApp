@page "/history"
@inject IVisitApiService VisitApi
@inject IPetApiService PetApi
@inject NavigationManager Nav

<div class="history-page">
    <div class="page-header">
        <h1 class="page-title">Historia leczenia</h1>
    </div>

    @if (loading)
    {
        <LoadingSpinner />
    }
    else if (loadError)
    {
        <div class="load-error">
            <span class="load-error-icon">&#x26A0;&#xFE0F;</span>
            <span class="load-error-text">Nie udało się wczytać historii</span>
            <span class="load-error-sub">Sprawdź połączenie i spróbuj ponownie.</span>
            <button class="retry-btn" @onclick="LoadAsync">Ponów</button>
        </div>
    }
    else
    {
        <div class="filter-chips">
            <button class="chip @(selectedPetId == null ? "chip-active" : "")" @onclick="() => selectedPetId = null">Wszystkie</button>
            @foreach (var p in pets)
            {
                var pid = p.Id;
                <button class="chip @(selectedPetId == pid ? "chip-active" : "")" @onclick="() => selectedPetId = pid" @key="p.Id">@p.Name</button>
            }
        </div>

        @if (FilteredVisits.Count == 0)
        {
            <div class="empty-state">
                <span class="empty-icon">&#x1F4CB;</span>
                <p class="empty-text">Brak wizyt do wyświetlenia</p>
            </div>
        }
        else
        {
            <div class="timeline">
                @foreach (var v in FilteredVisits)
                {
                    <div class="timeline-item" @key="v.Id" @onclick='() => Nav.NavigateTo($"/visits/{v.Id}")' style="cursor:pointer">
                        <div class="tl-left">
                            <div class="tl-dot" style="background:@VisitColor(v.Type); box-shadow: 0 0 8px @VisitColor(v.Type);"></div>
                            <div class="tl-line"></div>
                        </div>
                        <div class="tl-card">
                            <div class="tl-top">
                                <span class="tl-type" style="color:@VisitColor(v.Type)">@VisitLabel(v.Type)</span>
                                <span class="tl-date">@v.ScheduledAt.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="tl-pet-name">@v.PetName</div>
                            <div class="tl-doctor">@v.DoctorName</div>
                            <div class="tl-footer">
                                <span class="tl-time">@v.ScheduledAt.ToString("HH:mm")</span>
                                <span class="status-badge @StatusClass(v.Status)">@StatusLabel(v.Status)</span>
                            </div>
                            @if (v.Status == VisitStatus.Odwolana && !string.IsNullOrWhiteSpace(v.RejectionReason))
                            {
                                <div class="tl-reason">
                                    <span class="tl-reason-label">Powód odwołania:</span> @v.RejectionReason
                                </div>
                            }
                            @if (v.Status == VisitStatus.Zakonczona && !string.IsNullOrWhiteSpace(v.DoctorSummary))
                            {
                                <div class="tl-summary">
                                    <span class="tl-summary-label">Opis lekarza:</span> @Truncate(v.DoctorSummary)
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<VisitDto> visits = new();
    private List<PetDto> pets = new();
    private int? selectedPetId;
    private bool loading = true;
    private bool loadError;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        loadError = false;
        try
        {
            var vTask = VisitApi.GetVisitsAsync();
            var pTask = PetApi.GetPetsAsync();
            await Task.WhenAll(vTask, pTask);
            visits = vTask.Result.OrderByDescending(v => v.ScheduledAt).ToList();
            pets = pTask.Result;
        }
        catch { loadError = true; }
        finally { loading = false; }
    }

    private static string Truncate(string text) =>
        text.Length <= 120 ? text : text[..120] + "…";

    private List<VisitDto> FilteredVisits => selectedPetId.HasValue
        ? visits.Where(v => v.PetId == selectedPetId.Value).ToList()
        : visits;

    private static string VisitColor(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "var(--vSzczep)",
        VetMed.Shared.Enums.VisitType.Zabieg      => "var(--vZabieg)",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "var(--vDiag)",
        VetMed.Shared.Enums.VisitType.Nagly       => "var(--danger)",
        _                                          => "var(--vWizyta)"
    };

    private static string VisitLabel(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "Szczepienie",
        VetMed.Shared.Enums.VisitType.Kontrola    => "Kontrola",
        VetMed.Shared.Enums.VisitType.Zabieg      => "Zabieg",
        VetMed.Shared.Enums.VisitType.Nagly       => "Nagły",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "Diagnostyka",
        _                                          => t.ToString()
    };

    private static string StatusLabel(VetMed.Shared.Enums.VisitStatus s) => s switch
    {
        VetMed.Shared.Enums.VisitStatus.Oczekujaca   => "Oczekująca",
        VetMed.Shared.Enums.VisitStatus.Zaplanowana  => "Zaplanowana",
        VetMed.Shared.Enums.VisitStatus.Potwierdzona => "Potwierdzona",
        VetMed.Shared.Enums.VisitStatus.Zakonczona   => "Zakończona",
        VetMed.Shared.Enums.VisitStatus.Odwolana     => "Odwołana",
        _                                             => s.ToString()
    };

    private static string StatusClass(VetMed.Shared.Enums.VisitStatus s) => s switch
    {
        VetMed.Shared.Enums.VisitStatus.Zakonczona   => "badge-done",
        VetMed.Shared.Enums.VisitStatus.Odwolana     => "badge-cancelled",
        VetMed.Shared.Enums.VisitStatus.Potwierdzona => "badge-confirmed",
        _                                             => "badge-planned"
    };
}

<style>
    .history-page {
        padding: 20px 16px 8px;
    }

    .page-header {
        padding-top: 8px;
        margin-bottom: 18px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 800;
        color: var(--text);
    }

    .filter-chips {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 4px;
        margin-bottom: 20px;
        scrollbar-width: none;
    }

    .filter-chips::-webkit-scrollbar { display: none; }

    .chip {
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--textSub);
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
        flex-shrink: 0;
    }

    .chip-active {
        background: var(--mintGlow);
        border-color: var(--mint);
        color: var(--mint);
    }

    .timeline {
        display: flex;
        flex-direction: column;
    }

    .timeline-item {
        display: flex;
        gap: 12px;
        margin-bottom: 12px;
    }

    .tl-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 20px;
        flex-shrink: 0;
        padding-top: 4px;
    }

    .tl-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .tl-line {
        width: 2px;
        flex: 1;
        background: var(--border);
        margin-top: 6px;
    }

    .tl-card {
        flex: 1;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 14px 16px;
        box-shadow: var(--cardShadow);
    }

    .tl-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .tl-type {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .tl-date {
        font-size: 12px;
        color: var(--muted);
    }

    .tl-pet-name {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 2px;
    }

    .tl-doctor {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .tl-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .tl-time {
        font-size: 12px;
        color: var(--muted);
    }

    .status-badge {
        font-size: 11px;
        font-weight: 600;
        border-radius: 8px;
        padding: 3px 9px;
    }

    .tl-reason {
        margin-top: 10px;
        padding: 8px 10px;
        background: var(--dangerBg);
        border: 1px solid var(--danger);
        border-radius: 10px;
        font-size: 12px;
        color: var(--text);
        line-height: 1.4;
    }

    .tl-reason-label { color: var(--danger); font-weight: 700; }

    .tl-summary {
        margin-top: 10px;
        padding: 8px 10px;
        background: var(--okBg);
        border: 1px solid var(--okBorder);
        border-radius: 10px;
        font-size: 12px;
        color: var(--text);
        line-height: 1.4;
    }

    .tl-summary-label { color: var(--mint); font-weight: 700; }

    .badge-planned   { background: var(--mintGlow); color: var(--mint); }
    .badge-confirmed { background: var(--vDiagBg); color: var(--vDiag); }
    .badge-done      { background: var(--faint); color: var(--muted); }
    .badge-cancelled { background: var(--dangerBg);  color: var(--danger); }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 64px 20px;
        color: var(--muted);
        text-align: center;
    }

    .empty-icon { font-size: 44px; }
    .empty-text { font-size: 15px; }
</style>
