@page "/pets/{Id:int}"
@inject IPetApiService PetApi
@inject IVisitApiService VisitApi
@inject NavigationManager Nav

<div class="pet-card-page">
    @if (loading)
    {
        <LoadingSpinner />
    }
    else if (pet is null)
    {
        <div class="not-found">
            <p class="not-found-text">Nie znaleziono zwierzaka.</p>
            <button class="btn-back-sm" @onclick='() => Nav.NavigateTo("/pets")'>Wróć</button>
        </div>
    }
    else
    {
        <div class="hero">
            <button class="back-btn" @onclick='() => Nav.NavigateTo("/pets")'>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            @if (!string.IsNullOrEmpty(pet.ImageUrl))
            {
                <img class="hero-photo" src="@pet.ImageUrl" alt="@pet.Name" />
            }
            else
            {
                <div class="hero-emoji">@PetVisuals.Emoji(pet.Species)</div>
            }
            <h1 class="hero-name">@pet.Name</h1>
            <div class="hero-tags">
                <span class="hero-tag">@pet.Species</span>
                @if (!string.IsNullOrEmpty(pet.Breed))
                {
                    <span class="hero-tag">@pet.Breed</span>
                }
                <span class="hero-tag hero-tag-mint">@PetAge(pet.Born)</span>
            </div>
        </div>

        <div class="tabs-bar">
            <button class="tab @(activeTab == 0 ? "tab-active" : "")" @onclick="() => activeTab = 0">Opis</button>
            <button class="tab @(activeTab == 1 ? "tab-active" : "")" @onclick="() => activeTab = 1">Wizyty</button>
            <button class="tab @(activeTab == 2 ? "tab-active" : "")" @onclick="() => activeTab = 2">Szczepienia</button>
        </div>

        <div class="tab-content">
            @if (activeTab == 0)
            {
                <div class="info-card">
                    <div class="info-row">
                        <span class="info-label">Gatunek</span>
                        <span class="info-value">@pet.Species</span>
                    </div>
                    @if (pet.Sex != VetMed.Shared.Enums.PetSex.Nieznana)
                    {
                        <div class="info-row">
                            <span class="info-label">Płeć</span>
                            <span class="info-value">@SexLabel(pet.Sex)</span>
                        </div>
                    }
                    <div class="info-row">
                        <span class="info-label">Sterylizacja/kastracja</span>
                        <span class="info-value">@(pet.Sterilized ? "Tak" : "Nie")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(pet.Breed))
                    {
                        <div class="info-row">
                            <span class="info-label">Rasa</span>
                            <span class="info-value">@pet.Breed</span>
                        </div>
                    }
                    @if (pet.WeightKg.HasValue)
                    {
                        <div class="info-row">
                            <span class="info-label">Waga</span>
                            <span class="info-value">@pet.WeightKg kg</span>
                        </div>
                    }
                    <div class="info-row">
                        <span class="info-label">Data urodzin</span>
                        <span class="info-value">@pet.Born.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Wiek</span>
                        <span class="info-value info-value-mint">@PetAge(pet.Born)</span>
                    </div>
                    @if (!string.IsNullOrEmpty(pet.Color))
                    {
                        <div class="info-row">
                            <span class="info-label">Kolor</span>
                            <span class="info-value">@pet.Color</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(pet.MicrochipNumber))
                    {
                        <div class="info-row">
                            <span class="info-label">Mikrochip</span>
                            <span class="info-value">@pet.MicrochipNumber</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(pet.Notes))
                    {
                        <div class="info-row">
                            <span class="info-label">Uwagi</span>
                            <span class="info-value">@pet.Notes</span>
                        </div>
                    }
                </div>
            }
            else if (activeTab == 1)
            {
                @if (visitsLoading)
                {
                    <LoadingSpinner />
                }
                else if (petVisits.Count == 0)
                {
                    <p class="empty-msg">Brak wizyt.</p>
                }
                else
                {
                    @foreach (var v in petVisits)
                    {
                        <div class="visit-row" @key="v.Id">
                            <div class="visit-dot" style="background:@VisitColor(v.Type)"></div>
                            <div class="visit-details">
                                <div class="visit-type">@VisitLabel(v.Type)</div>
                                <div class="visit-meta">@v.ScheduledAt.ToString("dd MMM yyyy, HH:mm") · @v.DoctorName</div>
                            </div>
                            <span class="status-badge">@StatusLabel(v.Status)</span>
                        </div>
                    }
                }
            }
            else
            {
                @if (visitsLoading)
                {
                    <LoadingSpinner />
                }
                else
                {
                    var vaccines = petVisits.Where(v => v.Type == VetMed.Shared.Enums.VisitType.Szczepienie).ToList();
                    @if (vaccines.Count == 0)
                    {
                        <p class="empty-msg">Brak szczepień.</p>
                    }
                    else
                    {
                        @foreach (var v in vaccines)
                        {
                            <div class="visit-row" @key="v.Id">
                                <div class="visit-dot" style="background:var(--vSzczep)"></div>
                                <div class="visit-details">
                                    <div class="visit-type">Szczepienie</div>
                                    <div class="visit-meta">@v.ScheduledAt.ToString("dd MMM yyyy") · @v.DoctorName</div>
                                </div>
                            </div>
                        }
                    }
                }
            }
        </div>

        <div class="cta-wrap">
            <button class="btn-secondary" @onclick='() => Nav.NavigateTo($"/pets/{Id}/edit")'>
                Edytuj
            </button>
            <button class="btn-primary" @onclick='() => Nav.NavigateTo($"/book-visit?petId={Id}")'>
                Umów wizytę
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private PetDto? pet;
    private List<VisitDto> petVisits = new();
    private int activeTab;
    private bool loading = true;
    private bool visitsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try { pet = await PetApi.GetPetAsync(Id); }
        catch { }
        finally { loading = false; }

        visitsLoading = true;
        try { petVisits = (await VisitApi.GetVisitsByPetAsync(Id)).OrderByDescending(v => v.ScheduledAt).ToList(); }
        catch { }
        finally { visitsLoading = false; }
    }

    private static string SexLabel(VetMed.Shared.Enums.PetSex s) => s switch
    {
        VetMed.Shared.Enums.PetSex.Samiec => "Samiec",
        VetMed.Shared.Enums.PetSex.Samica => "Samica",
        _                                 => "Nieznana"
    };

    private static string PetAge(DateOnly born)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - born.Year) * 12 + today.Month - born.Month;
        if (today.Day < born.Day) months--;
        if (months < 12) return $"{months} mies.";
        var years = months / 12;
        return years == 1 ? "1 rok" : $"{years} lat";
    }

    private static string VisitColor(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "var(--vSzczep)",
        VetMed.Shared.Enums.VisitType.Zabieg      => "var(--vZabieg)",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "var(--vDiag)",
        VetMed.Shared.Enums.VisitType.Nagly       => "var(--danger)",
        _                                          => "var(--vWizyta)"
    };

    private static string VisitLabel(VetMed.Shared.Enums.VisitType t) => t switch
    {
        VetMed.Shared.Enums.VisitType.Szczepienie => "Szczepienie",
        VetMed.Shared.Enums.VisitType.Kontrola    => "Kontrola",
        VetMed.Shared.Enums.VisitType.Zabieg      => "Zabieg",
        VetMed.Shared.Enums.VisitType.Nagly       => "Nagły",
        VetMed.Shared.Enums.VisitType.Diagnostyka => "Diagnostyka",
        _                                          => t.ToString()
    };

    private static string StatusLabel(VetMed.Shared.Enums.VisitStatus s) => s switch
    {
        VetMed.Shared.Enums.VisitStatus.Zaplanowana  => "Zaplanowana",
        VetMed.Shared.Enums.VisitStatus.Potwierdzona => "Potwierdzona",
        VetMed.Shared.Enums.VisitStatus.Zakonczona   => "Zakończona",
        VetMed.Shared.Enums.VisitStatus.Odwolana     => "Odwołana",
        _                                             => s.ToString()
    };
}

<style>
    .pet-card-page {
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .hero {
        background: linear-gradient(180deg, var(--mintGlow) 0%, transparent 100%);
        padding: 20px 20px 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }

    .back-btn {
        position: absolute;
        left: 16px;
        top: 20px;
        background: var(--inputBg);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        width: 38px;
        height: 38px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .back-btn:hover { background: var(--mintGlow); }

    .hero-emoji { font-size: 72px; line-height: 1; margin-bottom: 14px; }

    .hero-photo {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 14px;
        border: 3px solid var(--border);
    }

    .hero-name {
        font-size: 28px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 12px;
    }

    .hero-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .hero-tag {
        background: var(--faint);
        border-radius: 10px;
        padding: 5px 13px;
        font-size: 12px;
        color: var(--textSub);
        font-weight: 600;
    }

    .hero-tag-mint {
        background: var(--mintGlow);
        color: var(--mint);
    }

    .tabs-bar {
        display: flex;
        background: var(--faint);
        margin: 0 16px;
        border-radius: 14px;
        padding: 4px;
        border: 1px solid var(--border);
    }

    .tab {
        flex: 1;
        background: transparent;
        border: none;
        color: var(--muted);
        font-size: 13px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        padding: 9px 4px;
        border-radius: 10px;
        cursor: pointer;
        transition: background 0.2s, color 0.2s;
    }

    .tab-active {
        background: var(--mintGlow);
        color: var(--mint);
    }

    .tab-content {
        padding: 16px;
        flex: 1;
    }

    .info-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 4px 0;
        box-shadow: var(--cardShadow);
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 13px 18px;
        border-bottom: 1px solid var(--faint);
    }

    .info-row:last-child { border-bottom: none; }

    .info-label {
        font-size: 14px;
        color: var(--muted);
    }

    .info-value {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .info-value-mint { color: var(--mint); }

    .visit-row {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 12px 14px;
        margin-bottom: 8px;
        box-shadow: var(--cardShadow);
    }

    .visit-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 8px currentColor;
    }

    .visit-details { flex: 1; }

    .visit-type {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .visit-meta {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    .status-badge {
        font-size: 11px;
        font-weight: 600;
        color: var(--mint);
        background: var(--mintGlow);
        border-radius: 8px;
        padding: 3px 8px;
        white-space: nowrap;
    }

    .empty-msg {
        text-align: center;
        color: var(--muted);
        font-size: 14px;
        padding: 40px 0;
    }

    .cta-wrap {
        padding: 12px 16px 20px;
        display: flex;
        gap: 10px;
    }

    .btn-secondary {
        background: var(--mintGlow);
        color: var(--mint);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 15px 20px;
        font-weight: 700;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s;
        white-space: nowrap;
    }

    .btn-secondary:active { transform: scale(0.98); }

    .btn-primary {
        flex: 1;
        background: var(--mint);
        color: var(--onMint);
        border: none;
        border-radius: 16px;
        padding: 15px;
        font-weight: 800;
        font-size: 15px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }

    .btn-primary:active { transform: scale(0.98); }

    .not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        padding: 80px 20px;
        color: var(--muted);
    }

    .not-found-text { font-size: 16px; }

    .btn-back-sm {
        background: var(--mintGlow);
        border: 1px solid var(--border);
        color: var(--mint);
        border-radius: 12px;
        padding: 10px 24px;
        font-size: 14px;
        font-weight: 700;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
    }
</style>
