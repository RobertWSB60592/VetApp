@startuml VetMed-Sekwencja-UmowWizyte
title VetMed — Diagram sekwencji: Umówienie wizyty

skinparam shadowing false

actor "Właściciel" as U
participant "Aplikacja\n(MAUI Blazor)" as App
participant "VisitsController\n(API)" as Ctrl
participant "CreateVisitValidator" as Val
participant "VisitService" as Svc
database "PostgreSQL\n(EF Core)" as DB

U -> App : Wybiera rodzaj, lekarza, termin
App -> Ctrl : POST /api/visits (CreateVisitDto) + JWT
Ctrl -> Val : Walidacja danych
alt Dane niepoprawne
  Val --> Ctrl : Błędy walidacji
  Ctrl --> App : 400 Bad Request (ProblemDetails)
  App --> U : Komunikat o błędzie
else Dane poprawne
  Val --> Ctrl : OK
  Ctrl -> Svc : CreateAsync(OwnerId, dto)
  Svc -> DB : Sprawdź zwierzę/lekarza i dostępność slotu
  alt Termin zajęty lub poza grafikiem
    Svc --> Ctrl : SlotUnavailable
    Ctrl --> App : 409 Conflict
    App --> U : "Termin jest już zajęty"
  else Termin dostępny
    Svc -> DB : INSERT Visit (Status = Oczekujaca)
    DB --> Svc : Visit Id
    Svc --> Ctrl : VisitDto (Created)
    Ctrl --> App : 201 Created
    App --> U : Potwierdzenie rezerwacji
  end
end

@enduml
