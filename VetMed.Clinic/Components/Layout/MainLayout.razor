@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 justify-content-end">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3 text-muted">@context.User.Identity?.Name</span>
                    <form method="post" action="/auth/logout" data-enhance="false" class="m-0">
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Wyloguj</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
